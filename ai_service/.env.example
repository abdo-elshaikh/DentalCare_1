# Copy to .env and fill in locally. Never commit .env with real API keys.

# Model Configuration
MODEL_PATH=models/best_model.pth
INPUT_SIZE=768
NUM_LANDMARKS=19
XRAY_VALIDATOR_MODEL_PATH=models/xray_validator.pt
XRAY_VALIDATOR_THRESHOLD=0.90

# API & URLs
CEPHALO_API_URL=http://localhost:8000
CEPHALO_UI_URL=http://localhost:8501

# LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# Clinical Thresholds
MIN_LANDMARK_CONFIDENCE=0.50
REQUIRE_CALIBRATION=true

