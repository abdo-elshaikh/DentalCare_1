@model IEnumerable<DentalCare.Models.Patient>
@{
    ViewData["Title"] = "My Patients";
}

<div class="d-flex flex-column gap-4 animate-fade-in-up">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1 tracking-tight">Patient Database</h1>
            <p class="text-secondary small mb-0">View and manage all registered patients.</p>
        </div>

        <div class="d-flex align-items-center gap-3 w-100 w-md-auto">
            <!-- Search Form -->
            <form asp-action="Patients" method="get" class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 400px;">
                <div class="flex-grow-1 position-relative">
                    <i class="fas fa-search position-absolute start-0 top-50 translate-middle-y ms-3 text-secondary opacity-50 small"></i>
                    <input type="text" name="searchString" placeholder="Search patients..."
                           class="form-control rounded-pill bg-white border-0 shadow-sm ps-5 py-2" style="font-size: 13px;" />
                </div>
                <button type="submit" class="btn btn-dark fw-bold px-4 rounded-pill shadow-sm transition hover-lift text-uppercase tracking-wider" style="font-size: 11px; padding-top: 10px; padding-bottom: 10px;">
                    Filter
                </button>
            </form>

            <a asp-controller="Patient" asp-action="Create" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm transition hover-lift d-flex align-items-center gap-2" style="padding-top: 10px; padding-bottom: 10px;">
                <i class="fas fa-plus"></i> <span class="d-none d-sm-inline">Register New</span>
            </a>
        </div>
    </div>

    <div class="glass-panel p-0 shadow-sm border-0 rounded-4 overflow-hidden animate-fade-in-up delay-100">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 border-white border-opacity-25">
                <thead class="bg-light bg-opacity-50 text-uppercase tracking-widest text-secondary" style="font-size: 10px; font-weight: 800;">
                    <tr>
                        <th class="px-4 py-3 border-0">Patient ID</th>
                        <th class="px-4 py-3 border-0">Name</th>
                        <th class="px-4 py-3 border-0">Age / Gender</th>
                        <th class="px-4 py-3 border-0">Contact</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-5 text-center text-muted fst-italic small fw-medium">No patients found in the database.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var patient in Model)
                        {
                            <tr class="transition" style="background-color: transparent;">
                                <td class="px-4 py-3 fw-bold text-secondary opacity-50 small border-bottom border-light">#@patient.Id</td>
                                <td class="px-4 py-3 border-bottom border-light">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="dental-avatar bg-primary-subtle text-primary fw-bold shadow-sm" style="width: 40px; height: 40px; border-radius: 12px; font-size: 14px;">
                                            @patient.Name[0].ToString().ToUpper()
                                        </div>
                                        <span class="fw-bold text-dark small">@patient.Name</span>
                                    </div>
                                </td>
                                <td class="px-4 py-3 border-bottom border-light">
                                    <div class="text-dark small fw-bold">@patient.Age <span class="text-secondary fw-normal">years</span></div>
                                    <div class="text-secondary" style="font-size: 11px;">@patient.Gender</div>
                                </td>
                                <td class="px-4 py-3 border-bottom border-light">
                                    <div class="text-dark small fw-bold">@patient.Phone</div>
                                    <div class="text-secondary" style="font-size: 11px;">@patient.Email</div>
                                </td>
                                <td class="px-4 py-3 text-end border-bottom border-light">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <a asp-controller="Patient" asp-action="Details" asp-route-id="@patient.Id" class="btn btn-white text-secondary border-secondary-subtle btn-sm fw-bold px-3 rounded-pill transition hover-lift" style="font-size: 11px;" title="Details">
                                            <i class="fas fa-eye me-1"></i> Details
                                        </a>
                                        <a asp-action="PatientProfile" asp-route-id="@patient.Id" class="btn btn-primary bg-gradient shadow-sm btn-sm fw-bold px-3 rounded-pill border-0 transition hover-lift" style="font-size: 11px;" title="History">
                                            <i class="fas fa-history me-1"></i> Record
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
