@model IEnumerable<DentalCare.Models.Patient>
@{
    ViewData["Title"] = "My Patients";
}

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-900">Patient Database</h1>
        <div class="flex gap-4">
            <div class="relative">
                <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
                <input type="text" placeholder="Search patients..." class="pl-10 pr-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-100" />
            </div>
            <a asp-controller="Patient" asp-action="Create" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
                <i class="fas fa-plus mr-2"></i> Register New
            </a>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead class="bg-gray-50 text-gray-400 text-xs uppercase font-bold">
                <tr>
                    <th class="px-6 py-4">Patient ID</th>
                    <th class="px-6 py-4">Name</th>
                    <th class="px-6 py-4">Age / Gender</th>
                    <th class="px-6 py-4">Contact</th>
                    <th class="px-6 py-4">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var patient in Model)
                {
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4 text-sm font-medium text-blue-600">@patient.Id</td>
                        <td class="px-6 py-4">
                            <span class="font-semibold text-gray-900">@patient.Name</span>
                        </td>
                        <td class="px-6 py-4 text-sm">@patient.Age years / @patient.Gender</td>
                        <td class="px-6 py-4">
                            <div class="text-sm text-gray-900">@patient.Phone</div>
                            <div class="text-xs text-gray-500">@patient.Email</div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex gap-3">
                                <a asp-controller="Patient" asp-action="Details" asp-route-id="@patient.Id" class="text-blue-600 hover:text-blue-800" title="Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="#" class="text-green-600 hover:text-green-800" title="History">
                                    <i class="fas fa-history"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center text-gray-500">
                            No patients found in the database.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
