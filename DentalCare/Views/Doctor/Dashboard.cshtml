@model IEnumerable<DentalCare.Models.Appointment>
@{
    ViewData["Title"] = "Doctor Dashboard";
    var latestAnalysisReportByPatientId =
        ViewBag.LatestAnalysisReportByPatientId as Dictionary<int, DentalCare.Models.AiAnalysisReport>
        ?? new Dictionary<int, DentalCare.Models.AiAnalysisReport>();
}
<!-- statistics Waiting, Total, Completed-->
<div class="row g-4 mb-5 animate-fade-in-up">
    <div class="col-md-4 delay-100">
        <div class="glass-panel rounded-4 shadow-sm border-0 h-100 p-4 hover-lift">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-secondary small fw-bold text-uppercase tracking-widest mb-1">Total Patients</p>
                    <h3 class="h2 fw-bold text-dark mb-0">@ViewBag.TotalPatients</h3>
                </div>
                <div class="dental-avatar bg-primary bg-gradient text-white shadow-sm"
                     style="width: 56px; height: 56px; border-radius: 16px;">
                    <i class="fas fa-users fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 delay-200">
        <div class="glass-panel rounded-4 shadow-sm border-0 h-100 p-4 hover-lift">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-secondary small fw-bold text-uppercase tracking-widest mb-1">Wait List</p>
                    <h3 class="h2 fw-bold text-dark mb-0">@ViewBag.WaitingCount</h3>
                </div>
                <div class="dental-avatar bg-warning bg-gradient text-white shadow-sm"
                     style="width: 56px; height: 56px; border-radius: 16px;">
                    <i class="fas fa-calendar-check fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 delay-300">
        <div class="glass-panel rounded-4 shadow-sm border-0 h-100 p-4 hover-lift">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-secondary small fw-bold text-uppercase tracking-widest mb-1">Completed Today</p>
                    <h3 class="h2 fw-bold text-dark mb-0">@ViewBag.CompletedCount</h3>
                </div>
                <div class="dental-avatar bg-success bg-gradient text-white shadow-sm"
                     style="width: 56px; height: 56px; border-radius: 16px;">
                    <i class="fas fa-check-circle fs-4"></i>
                </div>
            </div>
        </div>
    </div>
</div>
<!--End of statistics div-->

<div class="row g-4 animate-fade-in-up delay-200">
    <!-- Main Queue Section -->
    <div class="col-lg-8">
        <div class="glass-panel rounded-4 p-0 shadow-sm border-0 overflow-hidden h-100">
            <div
                class="p-4 border-bottom bg-white bg-opacity-75 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                <div>
                    <h3 class="h5 fw-bold text-dark mb-1 tracking-tight">Active Patient Queue</h3>
                    @{
                        var rawDoc = User.Identity?.Name;
                        var cleanDoc = rawDoc;
                        if (!string.IsNullOrEmpty(rawDoc))
                        {
                            if (rawDoc.Contains("@")) cleanDoc = rawDoc.Split('@')[0];
                            if (!string.IsNullOrEmpty(cleanDoc) && !cleanDoc.StartsWith("Dr. ",
                    StringComparison.OrdinalIgnoreCase)) cleanDoc = "Dr. " + cleanDoc;
                        }
                    }
                    <p class="text-secondary small fw-bold mb-0 text-uppercase tracking-widest" style="font-size: 10px;">Doctor: <span class="text-primary">@cleanDoc</span></p>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <form asp-action="Dashboard" method="get"
                          class="d-flex align-items-center gap-2 flex-grow-1 flex-md-grow-0" style="max-width: 400px;">
                        <div class="flex-grow-1 position-relative">
                            <i class="fas fa-search position-absolute start-0 top-50 translate-middle-y ms-3 text-secondary opacity-50 small"></i>
                            <input type="text" name="searchString" value="@ViewBag.SearchString"
                                   placeholder="Search patient..." class="form-control rounded-pill bg-light border-0 shadow-sm ps-5 py-2"
                                   style="font-size: 12px;" />
                        </div>
                        <button type="submit" class="btn btn-dark fw-bold px-4 rounded-pill shadow-sm transition hover-lift text-uppercase tracking-wider"
                                style="font-size: 10px; padding-top: 10px; padding-bottom: 10px;">Filter</button>
                    </form>

                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-md-none">
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill fw-bold">
                            <i class="fas fa-sign-out-alt"></i>
                        </button>
                    </form>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 border-white border-opacity-25">
                    <thead class="bg-light bg-opacity-50 text-uppercase tracking-widest text-secondary" style="font-size: 10px; font-weight: 800;">
                        <tr>
                            <th class="px-4 py-3 border-0">#</th>
                            <th class="px-4 py-3 border-0">Patient Name</th>
                            <th class="px-4 py-3 border-0">Type</th>
                            <th class="px-4 py-3 border-0 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-4 py-5 text-center text-muted fst-italic fw-medium">No patients in
                                    queue.</td>
                                </tr>
                            }
                        else
                            {
                                foreach (var appt in Model)
                                {
                                    var isXrayAppointment =
                                        string.Equals(appt.Type, "X-Ray", StringComparison.OrdinalIgnoreCase) ||
                                        string.Equals(appt.Type, "Xray", StringComparison.OrdinalIgnoreCase) ||
                                        string.Equals(appt.Type, "X Ray", StringComparison.OrdinalIgnoreCase);
                                    <tr class="transition" style="background-color: transparent;">
                                        <td class="px-4 py-3 border-bottom border-light fw-bold text-secondary opacity-50 small">#@appt.Id</td>
                                        <td class="px-4 py-3 border-bottom border-light">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="dental-avatar bg-primary-subtle text-primary fw-bold shadow-sm"
                                                     style="width: 36px; height: 36px; border-radius: 10px; font-size: 14px;">
                                                    @(appt.Patient?.Name?[0])</div>
                                                    <span class="fw-bold text-dark small">@appt.Patient?.Name</span>
                                                    @if (isXrayAppointment)
                                                    {
                                                        <a asp-action="Analysis" asp-route-patientId="@appt.PatientId"
                                                           title="Open AI analysis"
                                                           class="text-primary hover-primary transition"><i
                                                            class="fas fa-x-ray ms-2"></i></a>
                                                        }
                                                    </div>
                                                </td>
                                                <td class="px-4 py-3 border-bottom border-light small fw-bold text-uppercase text-secondary tracking-widest"
                                                    style="font-size: 10px;">@appt.Type</td>
                                                <td class="px-4 py-3 border-bottom border-light text-end">
                                                    @if (isXrayAppointment)
                                                    {
                                                        <a asp-action="Analysis" asp-route-patientId="@appt.PatientId"
                                                           class="btn btn-primary bg-gradient shadow-sm btn-sm fw-bold px-3 rounded-pill border-0 transition hover-lift" style="font-size: 11px;">
                                                            <i class="fas fa-x-ray me-1"></i> Analyze
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="PatientProfile" asp-route-id="@appt.PatientId"
                                                           asp-route-visitType="@appt.Type"
                                                           class="btn btn-white text-secondary border-secondary-subtle btn-sm fw-bold px-3 rounded-pill transition hover-lift" style="font-size: 11px;">
                                                            <i class="fas fa-folder-open me-1"></i> Open Record
                                                        </a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (ViewBag.TotalPages > 1)
                        {
                            <div class="p-4 bg-white bg-opacity-75 d-flex align-items-center justify-content-between">
                                <span class="text-secondary small fw-bold mb-0 text-uppercase tracking-widest" style="font-size: 10px;">Page @ViewBag.CurrentPage of @ViewBag.TotalPages</span>
                                <nav>
                                    <ul class="pagination pagination-sm mb-0 gap-2">
                                        @if (ViewBag.CurrentPage > 1)
                                        {
                                            <li class="page-item"><a asp-action="Dashboard"
                                                                         asp-route-pageNumber="@(ViewBag.CurrentPage - 1)"
                                                                         asp-route-searchString="@ViewBag.SearchString"
                                                                         class="btn btn-white text-secondary border-secondary-subtle btn-sm fw-bold rounded-pill px-3 transition hover-lift">Prev</a></li>
                                            }
                                            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                                            {
                                                <li class="page-item"><a asp-action="Dashboard"
                                                                             asp-route-pageNumber="@(ViewBag.CurrentPage + 1)"
                                                                             asp-route-searchString="@ViewBag.SearchString"
                                                                             class="btn btn-primary btn-sm fw-bold border-0 rounded-pill px-3 shadow-sm transition hover-lift">Next</a>
                                                </li>
                                            }
                                        </ul>
                                    </nav>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Completed Section -->
                    <div class="col-lg-4">
                        <div class="glass-panel rounded-4 p-0 shadow-sm border-0 overflow-hidden h-100">
                            <div class="p-4 border-bottom bg-success bg-opacity-10 d-flex align-items-center gap-3">
                                <div class="dental-avatar bg-success text-white rounded-circle shadow-sm" style="width: 40px; height: 40px;">
                                    <i class="fas fa-check-double"></i>
                                </div>
                                <div>
                                    <h3 class="h6 fw-bold text-dark mb-0 tracking-tight">Seen Today</h3>
                                    <p class="text-success small fw-bold mb-0 text-uppercase tracking-widest" style="font-size: 9px;">Completed Appointments</p>
                                </div>
                            </div>
                            <div class="p-4 bg-white bg-opacity-50">
                                @if (ViewBag.CompletedList is List<DentalCare.Models.Appointment> completedList && completedList.Any())
                                {
                                    <div class="d-flex flex-column gap-3">
                                        @foreach (var item in completedList)
                                        {
                                            var isCompletedXrayAppointment =
                                                string.Equals(item.Type, "X-Ray", StringComparison.OrdinalIgnoreCase) ||
                                                string.Equals(item.Type, "Xray", StringComparison.OrdinalIgnoreCase) ||
                                                string.Equals(item.Type, "X Ray", StringComparison.OrdinalIgnoreCase);
                                            <div
                                                class="d-flex align-items-center justify-content-between p-3 bg-white rounded-4 border border-light shadow-sm hover-lift transition">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="dental-avatar bg-success-subtle text-success rounded-3"
                                                         style="width: 36px; height: 36px; font-size: 12px;">
                                                        <i class="fas fa-check"></i>
                                                    </div>
                                                    <div>
                                                        <p class="small fw-bold text-dark mb-0">@item.Patient?.Name</p>
                                                        <p class="text-secondary fw-bold text-uppercase tracking-widest mb-0" style="font-size: 9px;">@item.Type</p>
                                                    </div>
                                                </div>
                                                @if (isCompletedXrayAppointment)
                                                {
                                                    @if (latestAnalysisReportByPatientId.TryGetValue(item.PatientId, out var analysisReport))
                                                    {
                                                        <a asp-action="AnalysisDetails" asp-route-id="@analysisReport.Id"
                                                           title="Open analysis details"
                                                           class="btn btn-light text-primary btn-sm rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center;"><i class="fas fa-chart-line"></i></a>
                                                    }
                                                    else
                                                    {
                                                        <a asp-action="Analysis" asp-route-patientId="@item.PatientId"
                                                           title="Run AI analysis"
                                                           class="btn btn-light text-warning btn-sm rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center;"><i class="fas fa-x-ray"></i></a>
                                                    }
                                                }
                                                else
                                                {
                                                    <a asp-action="PatientProfile" asp-route-id="@item.PatientId"
                                                       class="btn btn-light text-secondary btn-sm rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center;"><i class="fas fa-history"></i></a>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="py-5 text-center">
                                        <div class="dental-avatar bg-light text-secondary opacity-50 mx-auto mb-3" style="width: 64px; height: 64px; border-radius: 50%;">
                                            <i class="fas fa-list-check fs-3"></i>
                                        </div>
                                        <p class="text-secondary small fw-medium">No patients seen yet.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
