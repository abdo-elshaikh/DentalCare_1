@model DentalCare.Models.AiAnalysisReport
@using DentalCare.Models
@using DentalCare.ViewModels
@using System.Text.Json
@{
    ViewData["Title"] = "AI Analysis Details";
    var patient = ViewBag.Patient as Patient;
    var doctorName = ViewBag.DoctorName as string ?? "Unknown";
    var measurements = SafeDeserialize(Model.MeasurementRowsJson, new List<AiMeasurementReportItem>());
    var treatments = SafeDeserialize(Model.TreatmentsJson, new List<AiTreatmentReportItem>());
    var landmarks = SafeDeserialize(Model.LandmarksJson, new List<AiLandmarkReportItem>());
    var clinicalNotes = SafeDeserialize(Model.ClinicalNotesJson, new List<string>());
    var warnings = SafeDeserialize(Model.WarningsJson, new List<string>());
    var skeletalDifferential = SafeDeserialize(Model.SkeletalDifferentialJson, new Dictionary<string, float>());
    var originalImageUrl = Url.Action("AnalysisImage", "Doctor", new { id = Model.Id, kind = "original" });
    var overlayImageUrl = Url.Action("AnalysisImage", "Doctor", new { id = Model.Id, kind = "overlay" });
}

@functions {
    private static T SafeDeserialize<T>(string? json, T fallback)
    {
        if (string.IsNullOrWhiteSpace(json)) return fallback;
        try
        {
            return JsonSerializer.Deserialize<T>(
                json,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? fallback;
        }
        catch
        {
            return fallback;
        }
    }

    private static double NormalizeConfidence(double value)
    {
        var normalized = value > 1 ? value / 100d : value;
        return Math.Clamp(normalized, 0d, 1d);
    }

    private static string FormatConfidence(double? value) =>
        value.HasValue ? NormalizeConfidence(value.Value).ToString("P0") : "N/A";
}

<style>
    .metric-tile {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 16px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .metric-tile:hover { box-shadow: 0 6px 16px rgba(24,54,56,0.06); }
    .text-gradient {
        color: #172b2d;
    }
    .glass-panel {
        background: #fff;
        border: 1px solid #dce5e1;
        box-shadow: 0 10px 30px rgba(24,54,56,0.055);
    }
    .font-serif {
        font-family: 'DM Serif Display', serif;
    }
</style>

<div class="mb-4 d-flex align-items-center justify-content-between gap-3 flex-wrap">
    <a asp-action="PatientProfile" asp-route-id="@Model.PatientId"
       class="btn btn-link text-primary fw-bold text-decoration-none p-0 d-flex align-items-center gap-2 small">
        <i class="fas fa-arrow-left"></i> Back to Patient
    </a>
    <div class="d-flex align-items-center gap-3">
        <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 small fw-bold">
            Analysis #@Model.Id
        </span>
        <a asp-action="DownloadAnalysisPdf" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="fas fa-file-pdf me-2"></i> Download PDF
        </a>
    </div>
</div>

<div class="glass-panel rounded-4 p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
            <h1 class="h3 fw-bold font-serif text-gradient mb-1">AI Cephalometric Analysis</h1>
            <p class="dental-caption mb-0">
                @(patient?.Name ?? $"Patient #{Model.PatientId}") · @Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt") · @doctorName
            </p>
        </div>
        <div class="text-end">
            <p class="dental-caption mb-1">Protocol</p>
            <p class="fw-bold text-dark mb-0">@Model.ProtocolName</p>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <div class="col-md-4">
            <div class="metric-tile h-100">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="fas fa-bone text-primary opacity-75"></i>
                    <p class="dental-caption mb-0">Skeletal Class</p>
                </div>
                <p class="fs-5 fw-bold text-dark mb-0">@Model.SkeletalClass</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-tile h-100">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="fas fa-arrows-alt-v text-info opacity-75"></i>
                    <p class="dental-caption mb-0">Vertical Pattern</p>
                </div>
                <p class="fs-5 fw-bold text-dark mb-0">@Model.VerticalPattern</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-tile h-100">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="fas fa-brain text-purple opacity-75"></i>
                    <p class="dental-caption mb-0">Confidence</p>
                </div>
                <p class="fs-5 fw-bold text-dark mb-0">@FormatConfidence(Model.ConfidenceScore)</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-5">
        <div class="d-flex flex-column gap-4">
            <div class="glass-panel rounded-4 p-4">
                <h2 class="h5 fw-bold font-serif text-dark mb-4">Saved Images</h2>
                <div class="d-flex flex-column gap-4">
                    <div>
                        <p class="dental-caption mb-2">Original X-Ray</p>
                        @if (Model.OriginalImage is { Length: > 0 })
                        {
                            <img src="@originalImageUrl" alt="Original X-Ray" class="img-fluid rounded-3 border bg-light mb-3 shadow-sm" />
                            <a href="@originalImageUrl" class="btn btn-outline-primary btn-sm fw-bold rounded-pill px-3 w-100">
                                <i class="fas fa-download me-1"></i> Open Original
                            </a>
                        }
                        else
                        {
                            <div class="p-3 bg-light rounded-3 text-center border border-dashed">
                                <p class="small text-muted mb-0">No original image was saved.</p>
                            </div>
                        }
                    </div>
                    <div>
                        <p class="dental-caption mb-2">AI Overlay</p>
                        @if (Model.OverlayImage is { Length: > 0 })
                        {
                            <img src="@overlayImageUrl" alt="AI Overlay" class="img-fluid rounded-3 border bg-light mb-3 shadow-sm" />
                            <a href="@overlayImageUrl" class="btn btn-outline-primary btn-sm fw-bold rounded-pill px-3 w-100">
                                <i class="fas fa-eye me-1"></i> Open Overlay
                            </a>
                        }
                        else
                        {
                            <div class="p-3 bg-light rounded-3 text-center border border-dashed">
                                <p class="small text-muted mb-0">No overlay image was saved.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="glass-panel rounded-4 p-4">
                <h2 class="h5 fw-bold font-serif text-dark mb-3">Clinical Notes</h2>
                @if (clinicalNotes.Any())
                {
                    <ul class="small text-secondary mb-0 list-group list-group-flush border-0">
                        @foreach (var note in clinicalNotes)
                        {
                            <li class="list-group-item bg-transparent px-0 border-0 py-1"><i class="fas fa-check text-success me-2"></i>@note</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="small text-muted mb-0">No clinical notes saved.</p>
                }

                @if (warnings.Any())
                {
                    <div class="alert alert-warning border-0 rounded-3 small mt-4 mb-0 shadow-sm">
                        <p class="fw-bold mb-2 text-warning-emphasis"><i class="fas fa-exclamation-triangle me-2"></i>Warnings</p>
                        <ul class="mb-0 text-warning-emphasis">
                            @foreach (var warning in warnings)
                            {
                                <li>@warning</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="d-flex flex-column gap-4">
            <div class="glass-panel rounded-4 p-4">
                <h2 class="h5 fw-bold font-serif text-dark mb-3">Summary</h2>
                <p class="text-secondary mb-0" style="white-space: pre-wrap; font-size: 0.95rem; line-height: 1.6;">@Model.Summary</p>
                @if (!string.IsNullOrWhiteSpace(Model.ReviewNotes))
                {
                    <div class="p-4 bg-light rounded-3 mt-4 border-start border-4 border-primary">
                        <p class="dental-caption mb-1"><i class="fas fa-user-md me-1"></i> Doctor Review Notes</p>
                        <p class="small text-secondary mb-0 fw-medium">@Model.ReviewNotes</p>
                    </div>
                }
            </div>

            <div class="glass-panel rounded-4 p-4">
                <h2 class="h5 fw-bold font-serif text-dark mb-3">Measurements</h2>
                @if (measurements.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr class="dental-caption text-secondary">
                                    <th class="ps-3 border-0 rounded-start">Measurement</th>
                                    <th class="border-0">Value</th>
                                    <th class="border-0">Norm</th>
                                    <th class="border-0">Diff</th>
                                    <th class="pe-3 border-0 rounded-end text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in measurements.OrderBy(m => m.MeasurementName))
                                {
                                    <tr>
                                        <td class="fw-bold small ps-3">@item.MeasurementName</td>
                                        <td class="small fw-medium">@item.Value.ToString("0.0") @item.Unit</td>
                                        <td class="small text-muted">@(item.NormalValue.HasValue ? item.NormalValue.Value.ToString("0.0") : "N/A")</td>
                                        <td class="small text-muted">@(item.Difference.HasValue ? item.Difference.Value.ToString("+0.0;-0.0;0.0") : "N/A")</td>
                                        <td class="pe-3 text-center">
                                            @{
                                                var bgClass = item.Status.Equals("Normal", StringComparison.OrdinalIgnoreCase) ? "bg-success-subtle text-success" :
                                                              item.Status.Equals("Increased", StringComparison.OrdinalIgnoreCase) ? "bg-warning-subtle text-warning" :
                                                              item.Status.Equals("Decreased", StringComparison.OrdinalIgnoreCase) ? "bg-info-subtle text-info" :
                                                              "bg-light text-dark";
                                            }
                                            <span class="badge @bgClass border-0 rounded-pill px-3 py-2 w-100" style="max-width: 100px;">@item.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="small text-muted mb-0">No measurements saved.</p>
                }
            </div>

            <div class="glass-panel rounded-4 p-4">
                <h2 class="h5 fw-bold font-serif text-dark mb-4">Treatment Options</h2>
                @if (treatments.Any())
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var treatment in treatments)
                        {
                            <div class="metric-tile">
                                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-2">
                                    <p class="fw-bold text-dark mb-0 fs-6">@treatment.TreatmentName</p>
                                    @if (treatment.IsPrimary)
                                    {
                                        <span class="badge bg-primary text-white rounded-pill px-3 py-1 shadow-sm"><i class="fas fa-star me-1 small"></i> Primary</span>
                                    }
                                </div>
                                <p class="small text-secondary mb-3" style="line-height: 1.5;">@treatment.Description</p>
                                <div class="d-flex align-items-center gap-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="far fa-clock text-muted"></i>
                                        <span class="dental-caption mb-0">@treatment.DurationMonths months</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="fas fa-book-medical text-muted"></i>
                                        <span class="dental-caption mb-0">@treatment.EvidenceLevel</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="small text-muted mb-0">No treatment options saved.</p>
                }
            </div>

            @if (skeletalDifferential.Any())
            {
                <div class="glass-panel rounded-4 p-4">
                    <h2 class="h5 fw-bold font-serif text-dark mb-4">Skeletal Differential</h2>
                    <div class="row g-3">
                        @foreach (var item in skeletalDifferential.OrderByDescending(i => i.Value))
                        {
                            var normalizedDifferential = NormalizeConfidence(item.Value);
                            <div class="col-md-4">
                                <div class="metric-tile text-center h-100">
                                    <p class="dental-caption mb-2">@item.Key</p>
                                    <div class="progress mb-2" style="height: 6px;">
                                        <div class="progress-bar bg-primary rounded-pill" role="progressbar" style="width: @(normalizedDifferential * 100)%" aria-valuenow="@(normalizedDifferential * 100)" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <p class="fw-bold text-dark mb-0">@FormatConfidence(item.Value)</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="glass-panel rounded-4 p-4">
                <h2 class="h5 fw-bold font-serif text-dark mb-3">Landmarks</h2>
                @if (landmarks.Any())
                {
                    <div class="table-responsive border rounded-3" style="max-height: 360px;">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead class="table-light position-sticky top-0 shadow-sm" style="z-index: 1;">
                                <tr class="dental-caption text-secondary">
                                    <th class="ps-3 border-0">Name</th>
                                    <th class="border-0">X</th>
                                    <th class="border-0">Y</th>
                                    <th class="pe-3 border-0">Confidence</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var landmark in landmarks.OrderBy(l => l.Name))
                                {
                                    <tr>
                                        <td class="fw-bold small ps-3">@landmark.Name</td>
                                        <td class="small text-muted">@landmark.X.ToString("0.0")</td>
                                        <td class="small text-muted">@landmark.Y.ToString("0.0")</td>
                                        <td class="small pe-3">
                                            @if (landmark.Confidence.HasValue)
                                            {
                                                var normalizedConfidence = NormalizeConfidence(landmark.Confidence.Value);
                                                var confColor = normalizedConfidence > 0.8 ? "text-success" : normalizedConfidence > 0.5 ? "text-warning" : "text-danger";
                                                <span class="@confColor fw-medium">@FormatConfidence(landmark.Confidence)</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="small text-muted mb-0">No landmarks saved.</p>
                }
            </div>
        </div>
    </div>
</div>
