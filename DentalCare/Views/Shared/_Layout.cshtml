@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="request-verification-token" content="@antiforgeryToken" />
    <title>@ViewData["Title"] - DentalCare</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .text-gradient {
            background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .footer-gradient {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }
        .glass-header {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="bg-surface font-sans">
    <div class="min-vh-100 d-flex flex-column">
        <!-- Top Navigation Bar -->
        <header class="glass-header sticky-top z-3 text-nowrap">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center py-3">
                    <!-- Logo -->
                    <div class="d-flex align-items-center gap-2 text-primary">
                        <i class="fas fa-tooth fs-3"></i>
                        <span class="fs-3 fw-bold font-serif text-gradient tracking-tighter" style="line-height: 1;">DentalCare</span>
                    </div>

                    <!-- Main Navigation Links -->
                    <nav class="d-none d-md-flex align-items-center gap-4">
                        <a asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none hover-primary fw-bold small text-uppercase tracking-widest transition">Home</a>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Doctor"))
                            {
                                <a asp-controller="Doctor" asp-action="Dashboard" class="text-secondary text-decoration-none hover-primary fw-bold small text-uppercase tracking-widest transition">My Dashboard</a>
                                <a asp-controller="Doctor" asp-action="Analysis" class="text-secondary text-decoration-none hover-primary fw-bold small text-uppercase tracking-widest transition">AI Analysis</a>
                            }

                            @if (User.IsInRole("Staff") || User.IsInRole("Admin"))
                            {
                                <a asp-controller="Staff" asp-action="Dashboard" class="text-secondary text-decoration-none hover-primary fw-bold small text-uppercase tracking-widest transition">Reception</a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Users" class="text-secondary text-decoration-none hover-primary fw-bold small text-uppercase tracking-widest transition">Users</a>
                            }

                            <a asp-controller="Patient" asp-action="Index" class="text-secondary text-decoration-none hover-primary fw-bold small text-uppercase tracking-widest transition">Patients List</a>
                        }
                    </nav>

                    <!-- User Actions / Login Partial -->
                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="flex-grow-1">
            <div class="container py-5">
                @RenderBody()
            </div>
        </main>

        <!-- Footer -->
        <footer class="footer-gradient text-white py-5 mt-auto">
            <div class="container">
                <div class="row gy-4">
                    <div class="col-lg-4 col-md-6">
                        <div class="d-flex align-items-center gap-2 text-white mb-3">
                            <i class="fas fa-tooth fs-3" style="color: #0dcaf0;"></i>
                            <span class="fs-3 fw-bold font-serif tracking-tighter" style="line-height: 1;">DentalCare</span>
                        </div>
                        <p class="small text-white-50 pe-md-4">
                            Precision dental management software empowering clinics with AI-driven insights, seamless appointments, and secure medical records.
                        </p>
                    </div>
                    <div class="col-lg-2 col-md-6">
                        <h5 class="fw-bold text-white mb-3 small text-uppercase tracking-widest">Platform</h5>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none hover-primary transition small">Features</a></li>
                            <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none hover-primary transition small">AI Analysis</a></li>
                            <li class="mb-2"><a href="#" class="text-white-50 text-decoration-none hover-primary transition small">Pricing</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <h5 class="fw-bold text-white mb-3 small text-uppercase tracking-widest">Contact</h5>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2 text-white-50 small"><i class="fas fa-map-marker-alt me-2 text-primary"></i> 123 Health Ave, Medical City</li>
                            <li class="mb-2 text-white-50 small"><i class="fas fa-phone me-2 text-primary"></i> +1 (234) 567-890</li>
                            <li class="mb-2 text-white-50 small"><i class="fas fa-envelope me-2 text-primary"></i> contact@dentalcare.com</li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <h5 class="fw-bold text-white mb-3 small text-uppercase tracking-widest">Follow Us</h5>
                        <div class="d-flex gap-3">
                            <a href="#" class="text-white-50 hover-primary transition"><i class="fab fa-facebook fs-5"></i></a>
                            <a href="#" class="text-white-50 hover-primary transition"><i class="fab fa-twitter fs-5"></i></a>
                            <a href="#" class="text-white-50 hover-primary transition"><i class="fab fa-instagram fs-5"></i></a>
                            <a href="#" class="text-white-50 hover-primary transition"><i class="fab fa-linkedin fs-5"></i></a>
                        </div>
                    </div>
                </div>
                <hr class="border-secondary opacity-25 my-4" />
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                    <p class="small text-white-50 mb-0">&copy; 2026 DentalCare. All rights reserved.</p>
                    <div class="d-flex gap-3 mt-3 mt-md-0">
                        <a href="#" class="small text-white-50 text-decoration-none hover-primary transition">Privacy Policy</a>
                        <a href="#" class="small text-white-50 text-decoration-none hover-primary transition">Terms of Service</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const tokenMeta = document.querySelector('meta[name="request-verification-token"]');
            const token = tokenMeta ? tokenMeta.getAttribute('content') : '';
            if (!token || !window.fetch) return;

            const originalFetch = window.fetch.bind(window);
            window.fetch = (input, init = {}) => {
                const method = (init.method || 'GET').toUpperCase();
                if (!['GET', 'HEAD', 'OPTIONS', 'TRACE'].includes(method)) {
                    const headers = new Headers(init.headers || {});
                    if (!headers.has('RequestVerificationToken')) {
                        headers.set('RequestVerificationToken', token);
                    }
                    init = { ...init, headers };
                }
                return originalFetch(input, init);
            };
        })();
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
