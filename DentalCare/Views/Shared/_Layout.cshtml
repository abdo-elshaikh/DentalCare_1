@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var bodyClass = ViewData["BodyClass"] as string ?? string.Empty;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    string ActiveLink(string controller, string? action = null) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
        (action is null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase))
            ? "active"
            : string.Empty;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="request-verification-token" content="@antiforgeryToken" />
    <title>@ViewData["Title"] - DentalCare</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@bodyClass">
    <div class="site-shell">
        <header class="site-header">
            <nav class="navbar navbar-expand-lg container" aria-label="Main navigation">
                <a asp-controller="Home" asp-action="Index" class="brand-mark" aria-label="DentalCare home">
                    <span class="brand-symbol"><i class="fa-solid fa-tooth"></i></span>
                    <span>DentalCare<small>Clinical intelligence</small></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="collapse navbar-collapse" id="mainNavigation">
                    <div class="navbar-nav main-links mx-auto">
                        <a asp-controller="Home" asp-action="Index" class="nav-link @ActiveLink("Home", "Index")">Home</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Doctor"))
                            {
                                <a asp-controller="Doctor" asp-action="Dashboard" class="nav-link @ActiveLink("Doctor", "Dashboard")">Dashboard</a>
                                <a asp-controller="Doctor" asp-action="Analysis" class="nav-link @ActiveLink("Doctor", "Analysis")">AI analysis</a>
                            }
                            @if (User.IsInRole("Staff") || User.IsInRole("Admin"))
                            {
                                <a asp-controller="Staff" asp-action="Dashboard" class="nav-link @ActiveLink("Staff")">Reception</a>
                            }
                            @if (User.IsInRole("Doctor") || User.IsInRole("Staff"))
                            {
                                <a asp-controller="Patient" asp-action="Index" class="nav-link @ActiveLink("Patient")">Patients</a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Users" class="nav-link @ActiveLink("Admin")">Team</a>
                            }
                        }
                        else
                        {
                            <a asp-controller="Home" asp-action="Index" asp-fragment="capabilities" class="nav-link">Capabilities</a>
                            <a asp-controller="Account" asp-action="Login" class="nav-link d-lg-none">Sign in</a>
                        }
                    </div>
                    <div class="header-actions"><partial name="_LoginPartial" /></div>
                </div>
            </nav>
        </header>

        <main class="site-main">@RenderBody()</main>

        <footer class="site-footer">
            <div class="container footer-grid">
                <div class="footer-brand">
                    <a asp-controller="Home" asp-action="Index" class="brand-mark brand-mark--footer">
                        <span class="brand-symbol"><i class="fa-solid fa-tooth"></i></span><span>DentalCare<small>Clinical intelligence</small></span>
                    </a>
                    <p>Clinic operations and cephalometric insight, connected around the patient.</p>
                </div>
                <div>
                    <h2>Workspace</h2>
                    @if (User.IsInRole("Doctor"))
                    {
                        <a asp-controller="Doctor" asp-action="Dashboard">Doctor dashboard</a><a asp-controller="Patient" asp-action="Index">Patients</a><a asp-controller="Doctor" asp-action="Analysis">AI analysis</a>
                    }
                    else if (User.IsInRole("Staff"))
                    {
                        <a asp-controller="Staff" asp-action="Dashboard">Reception</a><a asp-controller="Patient" asp-action="Index">Patients</a>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Users">Team management</a><a asp-controller="Staff" asp-action="Dashboard">Reception</a>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Index" asp-fragment="capabilities">Capabilities</a><a asp-controller="Account" asp-action="Register">Create account</a>
                    }
                </div>
                <div><h2>Account</h2>@if (User.Identity?.IsAuthenticated == true) { <a asp-controller="Home" asp-action="Index">Home</a> } else { <a asp-controller="Account" asp-action="Login">Sign in</a><a asp-controller="Account" asp-action="Register">Register</a> }</div>
                <div class="footer-note"><h2>Built for clinical focus</h2><p>Role-based access for Admin, Doctor, and Staff teams.</p></div>
            </div>
            <div class="container footer-bottom"><span>&copy; @DateTime.UtcNow.Year DentalCare</span><span>Patient records · Scheduling · AI-assisted analysis</span></div>
        </footer>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
