@model DentalCare.Models.Patient
@{
    ViewData["Title"] = "Register Patient";
}

<div class="workspace-form-page">
    <a asp-action="Index" class="workspace-back"><i class="fas fa-arrow-left"></i> Back to patients</a>

    <section class="workspace-form-card glass-panel">
        <header class="workspace-form-header">
            <div class="dental-avatar"><i class="fas fa-user-plus"></i></div>
            <div>
                <h1>Register patient</h1>
                <p>Create a patient profile for scheduling and clinical records.</p>
            </div>
        </header>

        <form asp-action="Create" method="post" class="workspace-form-body" novalidate>
            <div asp-validation-summary="ModelOnly" class="auth-validation mb-3" role="alert"></div>
            <div class="workspace-form-grid">
                <div class="workspace-field--wide">
                    <label asp-for="Name" class="form-label dental-label">Full name</label>
                    <input asp-for="Name" class="form-control" autocomplete="name" placeholder="Patient's full name" required />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Age" class="form-label dental-label">Age</label>
                    <input asp-for="Age" type="number" class="form-control" min="1" max="120" required />
                    <span asp-validation-for="Age" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Gender" class="form-label dental-label">Gender</label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">Select gender</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                    <span asp-validation-for="Gender" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Phone" class="form-label dental-label">Phone number</label>
                    <input asp-for="Phone" class="form-control" autocomplete="tel" placeholder="Phone number" required />
                    <span asp-validation-for="Phone" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Email" class="form-label dental-label">Email address <span class="fw-normal text-secondary">(optional)</span></label>
                    <input asp-for="Email" type="email" class="form-control" autocomplete="email" placeholder="patient@example.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>
            </div>
            <div class="workspace-actions">
                <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-check"></i> Register patient</button>
            </div>
        </form>
    </section>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
