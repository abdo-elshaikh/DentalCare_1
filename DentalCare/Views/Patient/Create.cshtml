@model DentalCare.Models.Patient
@{
    ViewData["Title"] = "Register Patient";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="dental-card shadow-sm border-0 p-4 p-md-5">
                <h1 class="h3 fw-bold mb-4 text-dark text-center text-md-start">Patient Registration</h1>

                <form asp-action="Create" method="post" class="needs-validation">
                    <div class="mb-4">
                        <label class="form-label dental-label">Full Name</label>
                        <input asp-for="Name" class="dental-input" placeholder="Enter patient's full name" required />
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label dental-label">Age</label>
                            <input asp-for="Age" type="number" class="dental-input" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label dental-label">Gender</label>
                            <select asp-for="Gender" class="form-select dental-input shadow-none">
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label dental-label">Phone Number</label>
                        <input asp-for="Phone" class="dental-input" placeholder="000 000-00000" required />
                    </div>

                    <div class="mb-5">
                        <label class="form-label dental-label">Email Address</label>
                        <input asp-for="Email" type="email" class="dental-input" placeholder="email@example.com" />
                    </div>

                    <div class="d-grid pt-2">
                        <button type="submit" class="btn btn-primary fw-bold py-3 text-uppercase shadow-sm border-0 rounded-3" style="letter-spacing: 1px;">
                            Register Patient
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
