@model IEnumerable<DentalCare.Models.Patient>
@{
    ViewData["Title"] = "Patients Management";
}

<div class="d-flex flex-column gap-4 animate-fade-in-up">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1 tracking-tight">Patients Directory</h1>
            <p class="text-secondary small mb-0">Manage clinic patients and view their records.</p>
        </div>

        <div class="d-flex align-items-center gap-3 w-100 w-md-auto">
            <!-- Search Form -->
            <form asp-action="Index" method="get" class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 400px;">
                <div class="flex-grow-1 position-relative">
                    <i class="fas fa-search position-absolute start-0 top-50 translate-middle-y ms-3 text-secondary opacity-50 small"></i>
                    <input type="text" name="searchString" value="@ViewBag.SearchString" placeholder="Search by name/phone..."
                           class="form-control rounded-pill bg-white border-0 shadow-sm ps-5 py-2" style="font-size: 13px;" />
                </div>
                <button type="submit" class="btn btn-dark fw-bold px-4 rounded-pill shadow-sm transition hover-lift text-uppercase tracking-wider" style="font-size: 11px; padding-top: 10px; padding-bottom: 10px;">
                    Filter
                </button>
            </form>

            @if (!User.IsInRole("Doctor"))
            {
                <a asp-action="Create" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm transition hover-lift d-flex align-items-center gap-2" style="padding-top: 10px; padding-bottom: 10px;">
                    <i class="fas fa-plus"></i> <span class="d-none d-sm-inline">Register Patient</span>
                </a>
            }
        </div>
    </div>

    <div class="glass-panel p-0 shadow-sm border-0 rounded-4 overflow-hidden animate-fade-in-up delay-100">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 border-white border-opacity-25">
                <thead class="bg-light bg-opacity-50 text-uppercase tracking-widest text-secondary" style="font-size: 10px; font-weight: 800;">
                    <tr>
                        <th class="px-4 py-3 border-0">Patient ID</th>
                        <th class="px-4 py-3 border-0">Name</th>
                        <th class="px-4 py-3 border-0">Age</th>
                        <th class="px-4 py-3 border-0">Phone</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-5 text-center text-muted fst-italic small fw-medium">No patients found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var patient in Model)
                        {
                            <tr class="transition" style="background-color: transparent;">
                                <td class="px-4 py-3 fw-bold text-secondary opacity-50 small border-bottom border-light">#@patient.Id</td>
                                <td class="px-4 py-3 border-bottom border-light">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="dental-avatar bg-primary-subtle text-primary fw-bold shadow-sm" style="width: 40px; height: 40px; border-radius: 12px; font-size: 14px;">
                                            @patient.Name[0].ToString().ToUpper()
                                        </div>
                                        <span class="fw-bold text-dark small">@patient.Name</span>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-secondary small fw-bold border-bottom border-light">@patient.Age <span class="opacity-50 fw-normal">Yrs</span></td>
                                <td class="px-4 py-3 text-secondary small fw-bold border-bottom border-light">@patient.Phone</td>
                                <td class="px-4 py-3 text-end border-bottom border-light">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <a asp-action="Details" asp-route-id="@patient.Id" class="btn btn-white text-secondary border-secondary-subtle btn-sm fw-bold px-3 rounded-pill transition hover-lift" style="font-size: 11px;">
                                            <i class="fas fa-eye me-1"></i> Details
                                        </a>
                                        @if (!User.IsInRole("Doctor"))
                                        {
                                            <a asp-controller="Appointment" asp-action="Create" asp-route-patientId="@patient.Id" class="btn btn-primary bg-gradient shadow-sm btn-sm fw-bold px-3 rounded-pill border-0 transition hover-lift" style="font-size: 11px;">
                                                <i class="fas fa-calendar-plus me-1"></i> Book
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="p-4 bg-white bg-opacity-75 d-flex align-items-center justify-content-between">
                <p class="text-secondary small fw-bold mb-0 text-uppercase tracking-widest" style="font-size: 10px;">Page @ViewBag.CurrentPage of @ViewBag.TotalPages</p>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-2">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage - 1)" asp-route-searchString="@ViewBag.SearchString"
                                   class="btn btn-white text-secondary border-secondary-subtle btn-sm fw-bold rounded-pill px-3 transition hover-lift">Prev</a>
                            </li>
                        }
                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <li class="page-item">
                                <a asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage + 1)" asp-route-searchString="@ViewBag.SearchString"
                                   class="btn btn-primary btn-sm fw-bold border-0 rounded-pill px-3 shadow-sm transition hover-lift">Next</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
