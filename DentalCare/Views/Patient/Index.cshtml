@model IEnumerable<DentalCare.Models.Patient>
@{
    ViewData["Title"] = "Patients";
}

<div class="d-flex flex-column gap-4">
    <header class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3">
        <div>
            <div class="section-kicker"><i class="fas fa-address-book"></i> Patient registry</div>
            <h1 class="mt-2 mb-2">Patients</h1>
            <p class="small text-secondary mb-0">Find profiles, review records, and begin a new visit.</p>
        </div>
        <div class="d-flex flex-column flex-sm-row gap-2">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <div class="dental-search-container" style="min-width:min(320px, 65vw)"><i class="fas fa-search dental-search-icon"></i><input type="search" name="searchString" value="@ViewBag.SearchString" class="form-control dental-search-input" placeholder="Search name or phone" aria-label="Search patients" /></div>
                <button type="submit" class="btn btn-light px-3" title="Search"><i class="fas fa-search"></i><span class="d-none d-sm-inline">Search</span></button>
            </form>
            @if (!User.IsInRole("Doctor"))
            {
                <a asp-action="Create" class="btn btn-primary px-3"><i class="fas fa-user-plus"></i> Register patient</a>
            }
        </div>
    </header>

    <section class="glass-panel overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead><tr><th class="px-4">Patient</th><th>Age</th><th>Contact</th><th>Record ID</th><th class="text-end px-4">Actions</th></tr></thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="py-5 text-center"><div class="dental-avatar bg-secondary-subtle mx-auto mb-3"><i class="fas fa-user-slash"></i></div><p class="small fw-bold mb-1">No patients found</p><p class="small text-secondary mb-0">Try a different search or register a patient.</p></td></tr>
                }
                else
                {
                    @foreach (var patient in Model)
                    {
                        <tr>
                            <td class="px-4 py-3"><div class="d-flex align-items-center gap-3"><div class="dental-avatar bg-primary-subtle">@(string.IsNullOrEmpty(patient.Name) ? "?" : patient.Name[..1].ToUpperInvariant())</div><div><div class="small fw-bold text-dark">@patient.Name</div><div class="dental-caption">@patient.Gender</div></div></div></td>
                            <td class="small text-secondary">@patient.Age years</td>
                            <td><div class="small fw-bold">@patient.Phone</div><div class="dental-caption">@(patient.Email ?? "No email")</div></td>
                            <td><span class="badge bg-secondary-subtle">#@patient.Id</span></td>
                            <td class="text-end px-4"><div class="d-flex justify-content-end gap-2"><a asp-action="Details" asp-route-id="@patient.Id" class="btn btn-light btn-sm"><i class="fas fa-eye"></i> Details</a>@if (!User.IsInRole("Doctor")) { <a asp-controller="Appointment" asp-action="Create" asp-route-patientId="@patient.Id" class="btn btn-primary btn-sm"><i class="fas fa-calendar-plus"></i> Book</a> }</div></td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        @if (ViewBag.TotalPages > 1)
        {
            <footer class="p-3 px-4 border-top d-flex align-items-center justify-content-between gap-3"><span class="dental-caption">Page @ViewBag.CurrentPage of @ViewBag.TotalPages</span><div class="d-flex gap-2">@if (ViewBag.CurrentPage > 1) { <a asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage - 1)" asp-route-searchString="@ViewBag.SearchString" class="btn btn-light btn-sm"><i class="fas fa-arrow-left"></i> Previous</a> }@if (ViewBag.CurrentPage < ViewBag.TotalPages) { <a asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage + 1)" asp-route-searchString="@ViewBag.SearchString" class="btn btn-primary btn-sm">Next <i class="fas fa-arrow-right"></i></a> }</div></footer>
        }
    </section>
</div>
