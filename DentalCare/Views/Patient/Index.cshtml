@model IEnumerable<DentalCare.Models.Patient>
@{
    ViewData["Title"] = "Patients Management";
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <h1 class="h3 fw-bold text-dark mb-0">Patients List</h1>

        <div class="d-flex align-items-center gap-3 w-100 w-md-auto">
            <!-- Search Form -->
            <form asp-action="Index" method="get" class="d-flex align-items-center gap-2 flex-grow-1" style="max-width: 400px;">
                <div class="flex-grow-1 position-relative">
                    <i class="fas fa-search position-absolute start-0 top-50 translate-middle-y ms-3 text-secondary opacity-50 small"></i>
                    <input type="text" name="searchString" value="@ViewBag.SearchString" placeholder="Search by name/phone..."
                           class="dental-input py-2 ps-5 shadow-none border" />
                </div>
                <button type="submit" class="btn btn-dark fw-bold px-4 rounded-3 text-uppercase small" style="font-size: 11px;">Filter</button>
            </form>

            @if (!User.IsInRole("Doctor"))
            {
                <a asp-action="Create" class="dental-btn dental-btn-primary px-4">
                    <i class="fas fa-plus me-1"></i> <span class="d-none d-sm-inline">Register Patient</span>
                </a>
            }
        </div>
    </div>

    <div class="dental-card p-0 shadow-sm border-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 dental-caption">Patient ID</th>
                        <th class="px-4 py-3 dental-caption">Name</th>
                        <th class="px-4 py-3 dental-caption">Age</th>
                        <th class="px-4 py-3 dental-caption">Phone</th>
                        <th class="px-4 py-3 dental-caption text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-5 text-center text-muted fst-italic small font-medium">No patients found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var patient in Model)
                        {
                            <tr class="transition">
                                <td class="px-4 fw-black text-secondary opacity-50 small">#@patient.Id</td>
                                <td class="px-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="dental-avatar bg-primary-subtle text-primary fw-bold" style="width: 36px; height: 36px; border-radius: 10px; font-size: 14px;">
                                            @patient.Name[0].ToString().ToUpper()
                                        </div>
                                        <span class="fw-bold text-dark small">@patient.Name</span>
                                    </div>
                                </td>
                                <td class="px-4 text-secondary small fw-bold">@patient.Age <span class="opacity-50">Yrs</span></td>
                                <td class="px-4 text-secondary small fw-medium">@patient.Phone</td>
                                <td class="px-4 text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <a asp-action="Details" asp-route-id="@patient.Id" class="btn btn-outline-secondary border shadow-sm btn-sm fw-bold px-3 rounded-pill" style="font-size: 10px;">Details</a>
                                        @if (!User.IsInRole("Doctor"))
                                        {
                                            <a asp-controller="Appointment" asp-action="Create" asp-route-patientId="@patient.Id" class="btn btn-primary shadow-sm btn-sm fw-bold px-3 rounded-pill border-0" style="font-size: 10px;">Appointment</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="p-4 border-top bg-light d-flex align-items-center justify-content-between">
                <p class="dental-caption mb-0">Page @ViewBag.CurrentPage of @ViewBag.TotalPages</p>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-2">
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage - 1)" asp-route-searchString="@ViewBag.SearchString"
                                   class="btn btn-outline-secondary btn-sm fw-bold border rounded-pill px-3">Prev</a>
                            </li>
                        }
                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <li class="page-item">
                                <a asp-action="Index" asp-route-pageNumber="@(ViewBag.CurrentPage + 1)" asp-route-searchString="@ViewBag.SearchString"
                                   class="btn btn-primary btn-sm fw-bold border-0 rounded-pill px-3 shadow-sm">Next</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
