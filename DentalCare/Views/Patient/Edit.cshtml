@model DentalCare.Models.Patient
@{
    ViewData["Title"] = "Edit Patient Profile";
}

<div class="workspace-form-page">
    <a asp-action="Details" asp-route-id="@Model.Id" class="workspace-back"><i class="fas fa-arrow-left"></i> Back to patient profile</a>

    <section class="workspace-form-card glass-panel">
        <header class="workspace-form-header">
            <div class="dental-avatar"><i class="fas fa-user-pen"></i></div>
            <div>
                <h1>Edit patient</h1>
                <p>Update contact and demographic details for patient #@Model.Id.</p>
            </div>
        </header>

        <form asp-action="Edit" method="post" class="workspace-form-body">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="auth-validation mb-3" role="alert"></div>
            <div class="workspace-form-grid">
                <div class="workspace-field--wide">
                    <label asp-for="Name" class="form-label dental-label">Full name</label>
                    <input asp-for="Name" class="form-control" autocomplete="name" required />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Age" class="form-label dental-label">Age</label>
                    <input asp-for="Age" type="number" class="form-control" min="1" max="120" required />
                    <span asp-validation-for="Age" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Gender" class="form-label dental-label">Gender</label>
                    <select asp-for="Gender" class="form-select"><option value="Male">Male</option><option value="Female">Female</option></select>
                    <span asp-validation-for="Gender" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Phone" class="form-label dental-label">Phone number</label>
                    <input asp-for="Phone" class="form-control" autocomplete="tel" required />
                    <span asp-validation-for="Phone" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Email" class="form-label dental-label">Email address <span class="fw-normal text-secondary">(optional)</span></label>
                    <input asp-for="Email" type="email" class="form-control" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>
            </div>
            <div class="workspace-actions">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light px-4">Cancel</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-floppy-disk"></i> Save changes</button>
            </div>
        </form>
    </section>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
