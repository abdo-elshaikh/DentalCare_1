@model DentalCare.Models.Appointment
@{
    ViewData["Title"] = "New Appointment";
}

<div class="container py-4">
    <div class="mb-4">
        <a asp-controller="Patient" asp-action="Index" class="btn btn-link text-primary fw-bold text-decoration-none p-0 d-flex align-items-center gap-2 small">
            <i class="fas fa-arrow-left"></i> Back to Patients
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="bg-primary p-4 p-md-5 text-white">
                    <h1 class="h3 fw-bold mb-2">Book Appointment</h1>
                    <p class="mb-0 fw-bold opacity-75">Scheduling visit for <span class="text-white border-bottom border-white border-opacity-50">@ViewBag.PatientName</span></p>
                </div>

                <form asp-action="Create" method="post" class="p-4 p-md-5 bg-white">
                    <input type="hidden" asp-for="PatientId" />

                    <div class="mb-4">
                        <label asp-for="Date" class="form-label dental-label">Appointment Date & Time</label>
                        <input asp-for="Date" type="datetime-local" class="dental-input border shadow-none" required />
                        <span asp-validation-for="Date" class="text-danger small fw-bold mt-1 d-block ms-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Type" class="form-label dental-label">Visit Category</label>
                        <select asp-for="Type" class="form-select dental-input border shadow-none">
                            <option value="Checkup">General Checkup</option>
                            <option value="Cleaning">Teeth Cleaning</option>
                            <option value="X-Ray">X-Ray Analysis</option>
                            <option value="Extraction">Extraction</option>
                            <option value="Root Canal">Root Canal</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger small fw-bold mt-1 d-block ms-1"></span>
                    </div>

                    @if (User.IsInRole("Staff"))
                    {
                        <div class="mb-4">
                            <label asp-for="DoctorId" class="form-label dental-label">Assign Doctor</label>
                            <select asp-for="DoctorId" class="form-select dental-input border shadow-none" asp-items="ViewBag.DoctorList">
                                <option value="">-- Select Doctor --</option>
                            </select>
                            <span asp-validation-for="DoctorId" class="text-danger small fw-bold mt-1 d-block ms-1"></span>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="DoctorId" />
                    }

                    <div class="mb-5">
                        <label asp-for="Status" class="form-label dental-label">Initial Status</label>
                        <select asp-for="Status" class="form-select dental-input border shadow-none">
                            <option value="Pending">Pending Confirmation</option>
                            <option value="Confirmed">Confirmed</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small fw-bold mt-1 d-block ms-1"></span>
                    </div>

                    <div class="d-grid shadow-sm rounded-3 overflow-hidden">
                        <button type="submit" class="btn btn-primary fw-bold py-3 text-uppercase border-0" style="letter-spacing: 1px;">
                            Confirm Appointment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
