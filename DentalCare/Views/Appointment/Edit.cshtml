@model DentalCare.Models.Appointment
@{
    ViewData["Title"] = "Reschedule Appointment";
}

<div class="workspace-form-page">
    <a asp-controller="Staff" asp-action="Dashboard" class="workspace-back"><i class="fas fa-arrow-left"></i> Back to reception</a>

    <section class="workspace-form-card glass-panel">
        <header class="workspace-form-header">
            <div class="dental-avatar"><i class="fas fa-calendar-day"></i></div>
            <div>
                <h1>Edit appointment</h1>
                <p>Update the visit scheduled for <strong>@ViewBag.PatientName</strong>.</p>
            </div>
        </header>

        <form asp-action="Edit" method="post" class="workspace-form-body">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PatientId" />
            <div asp-validation-summary="ModelOnly" class="auth-validation mb-3" role="alert"></div>
            <div class="workspace-form-grid">
                <div class="workspace-field--wide">
                    <label asp-for="Date" class="form-label dental-label">Appointment date and time</label>
                    <input asp-for="Date" type="datetime-local" class="form-control" required />
                    <span asp-validation-for="Date" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Type" class="form-label dental-label">Visit category</label>
                    <select asp-for="Type" class="form-select"><option value="Checkup">General checkup</option><option value="Cleaning">Teeth cleaning</option><option value="X-Ray">X-ray analysis</option><option value="Extraction">Extraction</option><option value="Root Canal">Root canal</option></select>
                    <span asp-validation-for="Type" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="DoctorId" class="form-label dental-label">Assigned doctor</label>
                    <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.DoctorList"><option value="">Select doctor</option></select>
                    <span asp-validation-for="DoctorId" class="field-error"></span>
                </div>
                <div>
                    <label asp-for="Status" class="form-label dental-label">Status</label>
                    <select asp-for="Status" class="form-select"><option value="Pending">Pending confirmation</option><option value="Confirmed">Confirmed</option><option value="Completed">Completed</option><option value="Cancelled">Cancelled</option></select>
                    <span asp-validation-for="Status" class="field-error"></span>
                </div>
            </div>
            <div class="workspace-actions">
                <a asp-controller="Staff" asp-action="Dashboard" class="btn btn-light px-4">Cancel</a>
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-floppy-disk"></i> Save appointment</button>
            </div>
        </form>
    </section>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
