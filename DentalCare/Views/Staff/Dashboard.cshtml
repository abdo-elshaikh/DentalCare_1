@model IEnumerable<DentalCare.Models.Appointment>
@{
    ViewData["Title"] = "Reception Dashboard";
}

<div class="d-flex flex-column gap-3">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-start border-4 border-danger rounded-4 shadow-sm p-3 mb-0" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-exclamation-circle me-3"></i>
                <p class="mb-0 small fw-bold">@TempData["Error"]</p>
            </div>
        </div>
    }

   
    <div class="bg-white p-3 rounded-4 border shadow-sm d-flex flex-column xl:flex-row align-items-center justify-content-between gap-4">
        <!-- statistics Completed,waiting.... -->
        <div class="d-flex align-items-center gap-3">
            <div class="dental-avatar bg-primary text-white" style="width: 40px; height: 40px; border-radius: 12px;">
                <i class="fas fa-concierge-bell"></i>
            </div>
            <div>
                <h1 class="h6 fw-bolder text-dark mb-1">Reception</h1>
                <div class="d-flex align-items-center gap-2">
                    <span class="d-inline-block rounded-circle bg-warning" style="width: 6px; height: 6px;"></span>
                    <span class="dental-caption">@ViewBag.PendingCount Waiting</span>
                    <span class="d-inline-block rounded-circle bg-success ms-1" style="width: 6px; height: 6px;"></span>
                    <span class="dental-caption">@ViewBag.CompletedCount Done</span>
                </div>
            </div>
        </div>

        <!-- Inline Filter Form -->
        <form asp-action="Dashboard" method="get" class="flex-grow-1 d-flex flex-column flex-md-row align-items-center gap-2 w-100 mx-xl-4">
            <div style="min-width: 130px;" class="w-100 w-md-auto">
                <input type="date" name="searchDate" value="@ViewBag.SearchDate" class="dental-input py-1 shadow-none border" style="font-size: 13px;" />
            </div>

            <div style="min-width: 150px;" class="w-100 w-md-auto">
                <select name="doctorId" class="form-select dental-input py-1 shadow-none border" style="font-size: 13px;" asp-items="ViewBag.DoctorList">
                    <option value="">All Doctors</option>
                </select>
            </div>
            
            <div class="flex-grow-1 position-relative w-100 w-md-auto">
                <i class="fas fa-search position-absolute start-0 top-50 translate-middle-y ms-3 text-secondary opacity-50 small"></i>
                <input type="text" name="searchString" value="@ViewBag.SearchString" placeholder="Search name or phone..." class="dental-input py-1 ps-5 shadow-none border" style="font-size: 13px;" />
            </div>

            <div class="form-check form-switch ms-md-2 me-md-2" title="Show Completed">
                <input class="form-check-input" type="checkbox" name="showCompleted" value="true" id="showCompleted" @(ViewBag.ShowCompleted ? "checked" : "") onchange="this.form.submit()">
                <label class="form-check-label dental-caption pointer-cursor" for="showCompleted">Show Done</label>
            </div>
            
            <button type="submit" class="btn btn-primary fw-bold text-uppercase px-4 rounded-3 h-100" style="font-size: 11px; padding-top: 10px; padding-bottom: 10px;">
                Refresh
            </button>
        </form>

        <!-- Quick Actions -->
        <div class="d-flex align-items-center gap-2">
            <a asp-controller="Patient" asp-action="Create" class="btn btn-outline-secondary border-0 bg-light-subtle rounded-3 px-3 py-2 fw-bold text-uppercase small shadow-sm" style="font-size: 11px;">
                <i class="fas fa-user-plus me-1"></i> Patient
            </a>
            <a asp-controller="Patient" asp-action="Index" class="btn btn-dark rounded-3 px-3 py-2 fw-bold text-uppercase small shadow-sm" style="font-size: 11px;">
                <i class="fas fa-plus-circle me-1"></i> Book
            </a>
        </div>
    </div>

    <!-- Appointments Table (More compact) -->
    <div class="dental-card p-0 shadow-sm border-0 overflow-hidden">
        <div class="px-4 py-3 border-bottom bg-light d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="far fa-calendar-alt text-primary small"></i>
                <h3 class="h6 fw-bold text-dark mb-0">Schedule: @(DateTime.Parse(ViewBag.SearchDate).ToString("dd MMM yyyy"))</h3>
            </div>
            <span class="dental-caption">Total: @ViewBag.TotalCount</span>
        </div>
        
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 dental-caption">Time</th>
                        <th class="px-4 py-3 dental-caption">Patient Details</th>
                        <th class="px-4 py-3 dental-caption">Doctor</th>
                        <th class="px-4 py-3 dental-caption text-center">Status</th>
                        <th class="px-4 py-3 dental-caption text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-5 text-center text-muted fst-italic small font-medium">No appointments found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var appt in Model)
                        {
                            var isCompleted = appt.Status == "Completed";
                            <tr class="transition @(isCompleted ? "opacity-50 grayscale" : "")">
                                <td class="px-4">
                                    <span class="text-primary fw-bold small">@appt.Date.ToString("hh:mm tt")</span>
                                </td>
                                <td class="px-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="dental-avatar bg-light text-secondary fw-black small" style="width: 32px; height: 32px; font-size: 10px;">
                                            @(appt.Patient?.Name?[0].ToString().ToUpper() ?? "?")
                                        </div>
                                        <div class="text-truncate" style="max-width: 150px;">
                                            <p class="fw-bold text-dark small mb-0">@(appt.Patient?.Name ?? "Unknown")</p>
                                            <p class="dental-caption mb-0" style="font-size: 8px; opacity: 0.7;">@appt.Type</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4">
                                     @{
                                         var doctorNames = (ViewBag.DoctorNames as Dictionary<string, string>) ?? new Dictionary<string, string>();
                                         var docName = "Unknown";
                                         if (appt.DoctorId != null && doctorNames.ContainsKey(appt.DoctorId))
                                         {
                                             docName = doctorNames[appt.DoctorId];
                                         }
                                         else if (!string.IsNullOrEmpty(appt.DoctorId))
                                         {
                                             docName = appt.DoctorId.Length > 8 ? appt.DoctorId.Substring(0, 8) : appt.DoctorId;
                                         }

                                         if (docName != "Unknown" && !docName.StartsWith("Dr. ")) docName = "Dr. " + docName;
                                     }
                                     <span class="small fw-semibold text-secondary">@docName</span>
                                 </td>
                                <td class="px-4 text-center">
                                    @{
                                        var badgeClass = appt.Status == "Completed" ? "dental-badge-blue" : 
                                                        appt.Status == "Cancelled" ? "bg-danger bg-opacity-10 text-danger" : 
                                                        "bg-dark bg-opacity-10 text-dark";
                                    }
                                    <span class="dental-badge @badgeClass" style="font-size: 8px;">@appt.Status</span>
                                </td>
                                <td class="px-4 text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-1">
                                        @if (appt.Status != "Completed" && appt.Date.Date >= DateTime.Today)
                                        {
                                            <a asp-controller="Appointment" asp-action="Edit" asp-route-id="@appt.Id" class="btn btn-link btn-sm text-secondary hover-primary transition p-1" title="Edit">
                                                <i class="fas fa-edit small"></i>
                                            </a>
                                        }
                                        @if (appt.Status != "Completed" && appt.Status != "Cancelled")
                                        {
                                            <form asp-action="CancelAppointment" method="post" class="d-inline" onsubmit="return confirm('Cancel?')">
                                                <input type="hidden" name="id" value="@appt.Id" />
                                                <button type="submit" class="btn btn-link btn-sm text-secondary hover-danger transition p-1" title="Cancel">
                                                    <i class="fas fa-times-circle small"></i>
                                                </button>
                                            </form>
                                        }
                 
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paging -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-3">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm gap-2 border-0">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link rounded-3 border fw-bold px-3 py-2 shadow-sm @(i == ViewBag.CurrentPage ? "bg-primary text-white border-primary" : "bg-white text-secondary")" 
                               href="@Url.Action("Dashboard", new { 
                                   searchString = ViewBag.SearchString, 
                                   searchDate = ViewBag.SearchDate, 
                                   doctorId = ViewBag.SelectedDoctor, 
                                   showCompleted = ViewBag.ShowCompleted,
                                   pageNumber = i 
                               })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
</div>
