@model IEnumerable<DentalCare.Models.Appointment>
@{
    ViewData["Title"] = "Reception Dashboard";
}

<div class="d-flex flex-column gap-3 animate-fade-in-up">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 rounded-4 shadow-sm p-3 mb-0 d-flex align-items-center animate-fade-in-up" role="alert">
            <i class="fas fa-exclamation-circle me-3 fs-5"></i>
            <p class="mb-0 small fw-bold">@TempData["Error"]</p>
        </div>
    }

    <!-- Top Dashboard Bar -->
    <div class="glass-panel p-3 rounded-4 border-0 shadow-sm d-flex flex-column flex-xl-row align-items-center justify-content-between gap-4 hover-lift delay-100">
        <!-- statistics Completed,waiting.... -->
        <div class="d-flex align-items-center gap-3">
            <div class="dental-avatar bg-primary bg-gradient text-white shadow-sm" style="width: 48px; height: 48px; border-radius: 16px;">
                <i class="fas fa-concierge-bell fs-5"></i>
            </div>
            <div>
                <h1 class="h5 fw-bold text-dark mb-1 tracking-tight">Reception</h1>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-warning-subtle text-warning rounded-pill px-2 py-1" style="font-size: 10px;">
                        <i class="fas fa-circle me-1" style="font-size: 6px;"></i> @ViewBag.PendingCount Waiting
                    </span>
                    <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1" style="font-size: 10px;">
                        <i class="fas fa-circle me-1" style="font-size: 6px;"></i> @ViewBag.CompletedCount Done
                    </span>
                </div>
            </div>
        </div>

        <!-- Inline Filter Form -->
        <form asp-action="Dashboard" method="get" class="flex-grow-1 d-flex flex-column flex-md-row align-items-center gap-2 w-100 mx-xl-4">
            <div style="min-width: 140px;" class="w-100 w-md-auto">
                <input type="date" name="searchDate" value="@ViewBag.SearchDate" class="form-control rounded-pill bg-light border-0 shadow-sm px-3" style="font-size: 13px;" />
            </div>

            <div style="min-width: 160px;" class="w-100 w-md-auto">
                <select name="doctorId" class="form-select rounded-pill bg-light border-0 shadow-sm px-3" style="font-size: 13px;" asp-items="ViewBag.DoctorList">
                    <option value="">All Doctors</option>
                </select>
            </div>
            
            <div class="flex-grow-1 position-relative w-100 w-md-auto">
                <i class="fas fa-search position-absolute start-0 top-50 translate-middle-y ms-3 text-secondary opacity-50 small"></i>
                <input type="text" name="searchString" value="@ViewBag.SearchString" placeholder="Search name or phone..." class="form-control rounded-pill bg-light border-0 shadow-sm ps-5" style="font-size: 13px;" />
            </div>

            <div class="form-check form-switch ms-md-2 me-md-2" title="Show Completed">
                <input class="form-check-input shadow-none" type="checkbox" name="showCompleted" value="true" id="showCompleted" @(ViewBag.ShowCompleted ? "checked" : "") onchange="this.form.submit()">
                <label class="form-check-label text-secondary small fw-bold pointer-cursor text-uppercase tracking-widest" style="font-size: 10px;" for="showCompleted">Show Done</label>
            </div>
            
            <button type="submit" class="btn btn-primary fw-bold text-uppercase px-4 rounded-pill shadow-sm transition hover-lift h-100" style="font-size: 11px; padding-top: 10px; padding-bottom: 10px;">
                Refresh
            </button>
        </form>

        <!-- Quick Actions -->
        <div class="d-flex align-items-center gap-2">
            <a asp-controller="Patient" asp-action="Create" class="btn btn-light bg-white border-0 rounded-pill px-4 py-2 fw-bold text-uppercase small shadow-sm transition hover-lift text-primary" style="font-size: 11px;">
                <i class="fas fa-user-plus me-1"></i> Patient
            </a>
            <a asp-controller="Patient" asp-action="Index" class="btn btn-dark bg-gradient rounded-pill px-4 py-2 fw-bold text-uppercase small shadow-sm transition hover-lift" style="font-size: 11px;">
                <i class="fas fa-calendar-plus me-1"></i> Book
            </a>
        </div>
    </div>

    <!-- Appointments Table -->
    <div class="glass-panel p-0 shadow-sm border-0 rounded-4 overflow-hidden animate-fade-in-up delay-200">
        <div class="px-4 py-3 border-bottom bg-white bg-opacity-75 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <div class="dental-avatar bg-primary-subtle text-primary rounded-circle" style="width: 32px; height: 32px;">
                    <i class="far fa-calendar-alt small"></i>
                </div>
                <h3 class="h6 fw-bold text-dark mb-0 tracking-tight">Schedule: @(DateTime.Parse(ViewBag.SearchDate).ToString("dd MMM yyyy"))</h3>
            </div>
            <span class="badge bg-light border text-secondary rounded-pill px-3 py-1 fw-bold">Total: @ViewBag.TotalCount</span>
        </div>
        
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 border-white border-opacity-25">
                <thead class="bg-light bg-opacity-50 text-uppercase tracking-widest text-secondary" style="font-size: 10px; font-weight: 800;">
                    <tr>
                        <th class="px-4 py-3 border-0">Time</th>
                        <th class="px-4 py-3 border-0">Patient Details</th>
                        <th class="px-4 py-3 border-0">Doctor</th>
                        <th class="px-4 py-3 border-0 text-center">Status</th>
                        <th class="px-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-5 text-center text-muted fst-italic small fw-medium">No appointments found for this filter.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var appt in Model)
                        {
                            var isCompleted = appt.Status == "Completed";
                            <tr class="transition @(isCompleted ? "opacity-75 bg-light" : "")" style="background-color: transparent;">
                                <td class="px-4 border-bottom border-light">
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1 fw-bold shadow-sm" style="font-size: 12px;">
                                        <i class="far fa-clock me-1"></i> @appt.Date.ToString("hh:mm tt")
                                    </span>
                                </td>
                                <td class="px-4 border-bottom border-light">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="dental-avatar bg-secondary bg-opacity-10 text-secondary rounded-3 shadow-sm" style="width: 40px; height: 40px; font-size: 14px; font-weight: bold;">
                                            @(appt.Patient?.Name?[0].ToString().ToUpper() ?? "?")
                                        </div>
                                        <div class="text-truncate" style="max-width: 180px;">
                                            <p class="fw-bold text-dark small mb-0">@(appt.Patient?.Name ?? "Unknown")</p>
                                            <p class="text-secondary mb-0 text-uppercase tracking-widest" style="font-size: 9px; font-weight: 700;">@appt.Type</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 border-bottom border-light">
                                     @{
                                         var doctorNames = (ViewBag.DoctorNames as Dictionary<string, string>) ?? new Dictionary<string, string>();
                                         var docName = "Unknown";
                                         if (appt.DoctorId != null && doctorNames.ContainsKey(appt.DoctorId))
                                         {
                                             docName = doctorNames[appt.DoctorId];
                                         }
                                         else if (!string.IsNullOrEmpty(appt.DoctorId))
                                         {
                                             docName = appt.DoctorId.Length > 8 ? appt.DoctorId.Substring(0, 8) : appt.DoctorId;
                                         }

                                         if (docName != "Unknown" && !docName.StartsWith("Dr. ")) docName = "Dr. " + docName;
                                     }
                                     <span class="small fw-bold text-secondary bg-light px-2 py-1 rounded-2 border">@docName</span>
                                 </td>
                                <td class="px-4 text-center border-bottom border-light">
                                    @{
                                        var badgeClass = appt.Status == "Completed" ? "bg-success-subtle text-success" : 
                                                        appt.Status == "Cancelled" ? "bg-danger-subtle text-danger" : 
                                                        "bg-warning-subtle text-warning";
                                    }
                                    <span class="badge @badgeClass rounded-pill px-3 py-1 fw-bold shadow-sm" style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em;">@appt.Status</span>
                                </td>
                                <td class="px-4 text-end border-bottom border-light">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        @if (appt.Status != "Completed" && appt.Date.Date >= DateTime.Today)
                                        {
                                            <a asp-controller="Appointment" asp-action="Edit" asp-route-id="@appt.Id" class="btn btn-white text-primary border-primary-subtle btn-sm fw-bold rounded-pill px-3 transition hover-lift" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        }
                                        @if (appt.Status != "Completed" && appt.Status != "Cancelled")
                                        {
                                            <form asp-action="CancelAppointment" method="post" class="d-inline" onsubmit="return confirm('Cancel this appointment?')">
                                                <input type="hidden" name="id" value="@appt.Id" />
                                                <button type="submit" class="btn btn-white text-danger border-danger-subtle btn-sm fw-bold rounded-pill px-3 transition hover-lift" title="Cancel">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paging -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-center mt-4 animate-fade-in-up delay-300">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm gap-2 border-0 m-0">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link rounded-circle border-0 fw-bold shadow-sm transition hover-lift d-flex align-items-center justify-content-center @(i == ViewBag.CurrentPage ? "bg-primary text-white" : "bg-white text-secondary")" 
                               style="width: 36px; height: 36px;"
                               href="@Url.Action("Dashboard", new { 
                                   searchString = ViewBag.SearchString, 
                                   searchDate = ViewBag.SearchDate, 
                                   doctorId = ViewBag.SelectedDoctor, 
                                   showCompleted = ViewBag.ShowCompleted,
                                   pageNumber = i 
                               })">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
