@{
    ViewData["Title"] = "Access Denied";
    Layout = "_AuthLayout";
}

<section class="system-state">
    <div class="system-state__icon system-state__icon--danger"><i class="fas fa-lock"></i></div>
    <div class="section-kicker">Protected workspace</div>
    <h1>Access denied.</h1>
    <p>Your current clinic role does not include permission for this area. Return to your workspace or sign in with another authorized account.</p>
    <div class="system-state__actions">
        <a asp-controller="Account" asp-action="Login" class="btn btn-quiet px-4"><i class="fas fa-arrow-right-to-bracket"></i> Change account</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-brand px-4"><i class="fas fa-house"></i> Return home</a>
    </div>
</section>
