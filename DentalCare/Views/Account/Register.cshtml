@model DentalCare.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create account";
    Layout = "_AuthLayout";
}

<section class="auth-content auth-content--register">
    <div class="auth-form-pane">
        <div class="auth-form-wrap">
            <div class="section-kicker"><i class="fa-solid fa-user-plus"></i> Join your clinic team</div>
            <h1>Create your account.</h1>
            <p class="auth-lead">Use your work email. An administrator will assign your clinic role before your first sign-in.</p>
            <form asp-controller="Account" asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>
                <div class="field-group">
                    <label asp-for="Email">Work email address</label>
                    <div class="field-control"><i class="fa-regular fa-envelope"></i><input asp-for="Email" autocomplete="username" aria-required="true" placeholder="name@clinic.com" /></div>
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>
                <div class="field-group">
                    <label asp-for="Password">Password</label>
                    <div class="field-control"><i class="fa-solid fa-key"></i><input asp-for="Password" type="password" autocomplete="new-password" aria-required="true" placeholder="Create a secure password" /><button type="button" class="password-toggle" aria-label="Show password" title="Show password"><i class="fa-regular fa-eye"></i></button></div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <div class="password-rules"><span><i class="fa-solid fa-check"></i> 8+ characters</span><span><i class="fa-solid fa-check"></i> Upper and lowercase</span><span><i class="fa-solid fa-check"></i> Number and symbol</span></div>
                <div class="field-group">
                    <label asp-for="ConfirmPassword">Confirm password</label>
                    <div class="field-control"><i class="fa-solid fa-shield-halved"></i><input asp-for="ConfirmPassword" type="password" autocomplete="new-password" aria-required="true" placeholder="Repeat your password" /><button type="button" class="password-toggle" aria-label="Show password" title="Show password"><i class="fa-regular fa-eye"></i></button></div>
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>
                <button type="submit" class="btn btn-brand btn-lg auth-submit">Create account <i class="fa-solid fa-arrow-right"></i></button>
            </form>
            <p class="auth-switch">Already registered? <a asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">Sign in</a></p>
        </div>
    </div>
    <aside class="auth-story auth-story--register">
        <div class="auth-story__content">
            <span class="auth-story__eyebrow">Access that matches the work</span>
            <h2>Every team member sees the tools their role needs.</h2>
            <div class="role-preview"><div><i class="fa-solid fa-user-doctor"></i><strong>Doctor</strong><span>Clinical records and AI analysis</span></div><div><i class="fa-solid fa-clipboard-user"></i><strong>Staff</strong><span>Reception and appointments</span></div><div><i class="fa-solid fa-user-gear"></i><strong>Admin</strong><span>User and role management</span></div></div>
            <p class="approval-note"><i class="fa-solid fa-circle-info"></i> New accounts remain protected until an administrator assigns a role.</p>
        </div>
    </aside>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
