@model DentalCare.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="dental-card shadow-sm border-0">
            <div class="text-center mb-4">
                <div class="dental-avatar bg-primary-subtle text-primary mx-auto mb-3" style="width: 64px; height: 64px; border-radius: 1.25rem;">
                    <i class="fas fa-user-plus fs-4"></i>
                </div>
                <h1 class="h3 fw-bold text-dark">Create Account</h1>
                <p class="dental-caption">Join the DentalCare professional network</p>
            </div>

            <form asp-controller="Account" asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small fw-bold mb-3" role="alert"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="FullName" class="dental-label">Doctor's Full Name (Display Name)</label>
                        <input asp-for="FullName" class="dental-input" aria-required="true" placeholder="Ex: Dr. Ahmed Mohamed" title="Please enter your name as you want it to appear to patients" />
                        <span asp-validation-for="FullName" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Email" class="dental-label">Email Address</label>
                        <input asp-for="Email" class="dental-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password" class="dental-label">Password</label>
                        <input asp-for="Password" type="password" class="dental-input" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="dental-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="dental-input" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Role" class="dental-label">Register As</label>
                        <div class="row g-3">
                            <div class="col-6">
                                <input type="radio" asp-for="Role" value="Doctor" class="btn-check" id="roleDoctor" autocomplete="off" checked>
                                <label class="btn btn-outline-primary w-100 py-2 fw-bold small text-uppercase rounded-3" for="roleDoctor">
                                    <i class="fas fa-stethoscope me-2"></i> Doctor
                                </label>
                            </div>
                            <div class="col-6">
                                <input type="radio" asp-for="Role" value="Staff" class="btn-check" id="roleStaff" autocomplete="off">
                                <label class="btn btn-outline-primary w-100 py-2 fw-bold small text-uppercase rounded-3" for="roleStaff">
                                    <i class="fas fa-clipboard-user me-2"></i> Staff
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="my-4">
                    <button type="submit" class="dental-btn dental-btn-primary w-100 py-3 shadow-sm">
                        Register
                    </button>
                </div>

                <p class="text-center small text-secondary mt-3 mb-0 fw-bold text-uppercase tracking-widest" style="font-size: 10px;">
                    Already have an account? <a asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="text-primary text-decoration-none">Log in</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
