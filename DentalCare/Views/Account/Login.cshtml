@model DentalCare.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-5">
        <div class="dental-card shadow-sm border-0">
            <div class="text-center mb-4">
                <div class="dental-avatar bg-primary-subtle text-primary mx-auto mb-3" style="width: 64px; height: 64px; border-radius: 1.25rem;">
                    <i class="fas fa-lock fs-4"></i>
                </div>
                <h1 class="h3 fw-bold text-dark">Welcome Back</h1>
                <p class="dental-caption">Please sign in to continue</p>
            </div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                @if (TempData["InfoMessage"] is string infoMessage)
                {
                    <div class="alert alert-info small fw-semibold border-0 rounded-3" role="status">
                        @infoMessage
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="dental-label">Email Address</label>
                    <input asp-for="Email" class="dental-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger small fw-bold"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="dental-label">Password</label>
                    <input asp-for="Password" type="password" class="dental-input" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small fw-bold"></span>
                </div>

                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label small fw-semibold text-secondary">Remember me</label>
                    </div>
                </div>

                <button type="submit" class="dental-btn dental-btn-primary w-100 py-3 shadow-sm">
                    Sign In
                </button>

                <p class="text-center small text-secondary mt-4 mb-0 fw-bold text-uppercase tracking-widest" style="font-size: 10px;">
                    New here? <a asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="text-primary text-decoration-none">Create Account</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
