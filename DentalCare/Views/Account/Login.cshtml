@model DentalCare.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "_AuthLayout";
}

<section class="auth-content">
    <div class="auth-form-pane">
        <div class="auth-form-wrap">
            <div class="section-kicker"><i class="fa-solid fa-lock"></i> Secure clinic access</div>
            <h1>Welcome back.</h1>
            <p class="auth-lead">Sign in to continue to your DentalCare workspace.</p>

            @if (TempData["InfoMessage"] is string infoMessage)
            {
                <div class="auth-alert auth-alert--info" role="status"><i class="fa-solid fa-circle-info"></i><span>@infoMessage</span></div>
            }
            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>
                <div class="field-group">
                    <label asp-for="Email">Email address</label>
                    <div class="field-control"><i class="fa-regular fa-envelope"></i><input asp-for="Email" autocomplete="username" aria-required="true" placeholder="name@clinic.com" /></div>
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>
                <div class="field-group">
                    <label asp-for="Password">Password</label>
                    <div class="field-control"><i class="fa-solid fa-key"></i><input asp-for="Password" type="password" autocomplete="current-password" aria-required="true" placeholder="Enter your password" /><button type="button" class="password-toggle" aria-label="Show password" title="Show password"><i class="fa-regular fa-eye"></i></button></div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <label class="remember-control"><input asp-for="RememberMe" /> <span>Keep me signed in on this device</span></label>
                <button type="submit" class="btn btn-brand btn-lg auth-submit">Sign in <i class="fa-solid fa-arrow-right"></i></button>
            </form>
            <p class="auth-switch">New to DentalCare? <a asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]">Request an account</a></p>
        </div>
    </div>
    <aside class="auth-story auth-story--login">
        <div class="auth-story__content">
            <span class="auth-story__eyebrow">Your clinical day, connected</span>
            <h2>Move from schedule to patient record to analysis without breaking focus.</h2>
            <div class="auth-story__features">
                <div><i class="fa-regular fa-calendar-check"></i><span><strong>Appointments</strong>Visit type, doctor, date, and status</span></div>
                <div><i class="fa-solid fa-notes-medical"></i><span><strong>Medical records</strong>Diagnosis and visit history in context</span></div>
                <div><i class="fa-solid fa-wand-magic-sparkles"></i><span><strong>AI reports</strong>Measurements, findings, and review notes</span></div>
            </div>
        </div>
    </aside>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
