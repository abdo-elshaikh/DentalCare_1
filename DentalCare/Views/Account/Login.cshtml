@model DentalCare.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Log in";
    Layout = "_AuthLayout";
}

<div class="row g-0 bg-white rounded-5 shadow-lg overflow-hidden my-4" style="min-height: 700px;">
    <!-- Left Side - Form -->
    <div class="col-lg-6 d-flex flex-column justify-content-center p-5 p-xl-5">
        <div class="w-100" style="max-width: 450px; margin: 0 auto;">
            <div class="text-center mb-5">
                <div class="dental-avatar bg-primary-subtle text-primary mx-auto mb-3" style="width: 64px; height: 64px; border-radius: 1.25rem;">
                    <i class="fas fa-lock fs-4"></i>
                </div>
                <h1 class="h2 fw-bold text-dark tracking-tight">Welcome Back</h1>
                <p class="text-secondary small">Please sign in to continue to DentalCare</p>
            </div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                @if (TempData["InfoMessage"] is string infoMessage)
                {
                    <div class="alert alert-info small fw-semibold border-0 rounded-3 shadow-sm" role="status">
                        @infoMessage
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="text-danger small fw-bold mb-3" role="alert"></div>

                <div class="form-floating mb-4">
                    <input asp-for="Email" class="form-control rounded-4 bg-light border-0 px-4" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Email" class="px-4 text-secondary small">Email Address</label>
                    <span asp-validation-for="Email" class="text-danger small fw-bold mt-1 d-block px-2"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Password" type="password" class="form-control rounded-4 bg-light border-0 px-4" autocomplete="current-password" aria-required="true" placeholder="Password" />
                    <label asp-for="Password" class="px-4 text-secondary small">Password</label>
                    <span asp-validation-for="Password" class="text-danger small fw-bold mt-1 d-block px-2"></span>
                </div>

                <div class="d-flex align-items-center justify-content-between mb-5 px-2">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input shadow-none" />
                        <label asp-for="RememberMe" class="form-check-label small fw-semibold text-secondary user-select-none">Remember me</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold shadow-sm hover-lift text-uppercase tracking-wider">
                    Sign In to Dashboard
                </button>

                <div class="text-center mt-5">
                    <p class="small text-secondary fw-semibold">
                        Don't have an account yet? 
                        <a asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="text-primary text-decoration-none fw-bold ms-1">Create Account</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
    
    <!-- Right Side - Image/Branding -->
    <div class="col-lg-6 d-none d-lg-block position-relative p-3">
        <div class="bg-primary h-100 rounded-5 w-100 position-relative overflow-hidden hero-gradient-bg">
            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column justify-content-center align-items-center text-center p-5 z-1">
                <i class="fas fa-tooth text-white opacity-25 mb-4" style="font-size: 8rem;"></i>
                <h2 class="text-dark fw-bold display-6 mb-3">Precision Dental Management</h2>
                <p class="text-secondary fs-5 mx-auto" style="max-width: 400px;">Streamline your clinic operations and leverage AI-driven insights for better patient care.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
