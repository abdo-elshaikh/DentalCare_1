@model DentalCare.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Welcome to DentalCare";
}

<div class="py-5 hero-gradient-bg mb-5" style="border-radius: 2rem;">
    <!-- Hero Section -->
    <section class="text-center py-5 container animate-fade-in-up">
        <div class="d-inline-flex align-items-center gap-2 px-3 py-2 bg-white rounded-pill shadow-sm mb-4 border border-primary-subtle delay-100">
            <span class="badge bg-primary rounded-pill">New</span>
            <span class="small fw-semibold text-secondary">AI-Powered Dental Analysis Now Available</span>
        </div>
        <h1 class="display-3 fw-bolder text-dark mb-4 tracking-tight delay-200">
            Digital Solution for Your <span class="text-primary position-relative">Dental Practice
                <svg class="position-absolute bottom-0 start-0 w-100 text-primary opacity-25" style="height: 12px; margin-bottom: -4px;" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0,5 Q50,15 100,5" stroke="currentColor" stroke-width="4" fill="none"/></svg>
            </span>
        </h1>
        <p class="lead text-secondary mx-auto mb-5 delay-300" style="max-width: 700px;">
            Manage your patients, appointments, and medical records with ease. Advanced AI analysis at your fingertips. Join the future of dental care.
        </p>
        <div class="d-flex justify-content-center flex-wrap gap-3 mt-4 delay-400">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary px-5 py-3 rounded-pill fw-bold shadow-lg transition hover-lift text-uppercase tracking-wider" style="font-size: 0.9rem;">
                Start Free Trial
            </a>
            <a href="#features" class="btn btn-white bg-white border border-secondary-subtle px-5 py-3 rounded-pill fw-bold shadow-sm transition hover-lift text-uppercase tracking-wider" style="font-size: 0.9rem;">
                Explore Features
            </a>
        </div>
    </section>
    
    <!-- Stats Section (Dynamic Data) -->
    <section class="container mt-5 pb-5 animate-fade-in-up delay-400">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="glass-panel text-center p-4 rounded-4 hover-lift">
                    <h2 class="display-5 fw-bold text-primary mb-1">@(Model?.TotalPatients ?? 0)</h2>
                    <p class="text-secondary fw-semibold mb-0 text-uppercase tracking-widest small">Registered Patients</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-panel text-center p-4 rounded-4 hover-lift">
                    <h2 class="display-5 fw-bold text-success mb-1">@(Model?.TotalAppointments ?? 0)</h2>
                    <p class="text-secondary fw-semibold mb-0 text-uppercase tracking-widest small">Appointments Booked</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-panel text-center p-4 rounded-4 hover-lift">
                    <h2 class="display-5 fw-bold text-info mb-1">@(Model?.TotalAiAnalyses ?? 0)</h2>
                    <p class="text-secondary fw-semibold mb-0 text-uppercase tracking-widest small">AI Analyses Performed</p>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Why Choose DentalCare Section -->
<section id="features" class="py-5 mb-5 container">
    <div class="text-center mb-5 animate-fade-in-up">
        <span class="text-primary fw-bold text-uppercase tracking-widest small mb-2 d-block">Platform Features</span>
        <h2 class="display-5 fw-bold text-dark mb-3">Everything you need to run your clinic</h2>
        <p class="text-secondary mx-auto" style="max-width: 600px;">
            We provide a comprehensive suite of tools designed to make dental and orthodontic management
            simple, secure, and highly efficient.
        </p>
    </div>
    <div class="row g-4">
        <div class="col-md-4 animate-fade-in-up delay-100">
            <div class="dental-card h-100 shadow-sm border-0 hover-lift">
                <div class="dental-avatar bg-primary-subtle text-primary mb-4" style="width: 56px; height: 56px; border-radius: 1rem;">
                    <i class="fas fa-calendar-check fs-4"></i>
                </div>
                <h3 class="h5 fw-bold text-dark mb-3">Smart Scheduling</h3>
                <p class="text-secondary small mb-0">Fast, reliable, and conflict-free online dental appointment system for both patients and doctors.</p>
            </div>
        </div>

        <div class="col-md-4 animate-fade-in-up delay-200">
            <div class="dental-card h-100 shadow-sm border-0 hover-lift">
                <div class="dental-avatar bg-success-subtle text-success mb-4" style="width: 56px; height: 56px; border-radius: 1rem;">
                    <i class="fas fa-users fs-4"></i>
                </div>
                <h3 class="h5 fw-bold text-dark mb-3">Secure Records</h3>
                <p class="text-secondary small mb-0">Compliant digital storage for all patient histories, X-rays, and comprehensive treatment plans.</p>
            </div>
        </div>

        <div class="col-md-4 animate-fade-in-up delay-300">
            <div class="dental-card h-100 shadow-sm border-0 hover-lift">
                <div class="dental-avatar bg-info-subtle text-info mb-4" style="width: 56px; height: 56px; border-radius: 1rem;">
                    <i class="fas fa-robot fs-4"></i>
                </div>
                <h3 class="h5 fw-bold text-dark mb-3">AI Intelligence</h3>
                <p class="text-secondary small mb-0">Leverage cutting-edge machine learning models to detect ceph issues before they become serious.</p>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="container mb-5">
    <div class="bg-primary rounded-5 p-5 text-center text-white shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);">
        <div class="position-absolute top-0 end-0 opacity-25 w-50 h-100" style="background: radial-gradient(circle, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0) 70%); transform: translate(30%, -30%);"></div>
        <div class="py-4 position-relative z-1 animate-fade-in-up">
            <h2 class="display-6 fw-bold mb-3">Ready to transform your practice?</h2>
            <p class="mb-4 opacity-75 mx-auto fs-5" style="max-width: 700px;">Join leading dental professionals who trust DentalCare for their daily clinical management and AI analysis.</p>
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5 py-3 rounded-pill fw-bold text-primary shadow-sm hover-lift text-uppercase tracking-wider" style="font-size: 0.9rem;">
                Create Your Free Account
            </a>
        </div>
    </div>
</section>
