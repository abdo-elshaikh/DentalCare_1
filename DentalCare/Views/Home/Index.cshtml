@{
    ViewData["Title"] = "Welcome to DentalCare";
}


<div class="py-5">
    <!-- Hero Section -->
    <section class="text-center mb-5 py-5">
        <h1 class="display-3 fw-bolder text-dark mb-4 tracking-tight">
            Digital Solution for Your <span class="text-primary">Dental Practice</span>
        </h1>
        <p class="lead text-secondary mx-auto mb-5" style="max-width: 700px;">
            Manage your patients, appointments, and medical records with ease. Advanced AI analysis at your fingertips.
        </p>
        <div class="d-flex justify-content-center flex-wrap gap-3 mt-4">
            <a asp-controller="Doctor" asp-action="Dashboard" class="btn btn-primary px-5 py-3 rounded-4 fw-bold shadow transition">
                Get Started
            </a>
            <a href="#contact" class="btn btn-success px-5 py-3 rounded-4 fw-bold shadow transition">
                <i class="fas fa-phone-alt me-2"></i> Contact Us
            </a>
            <a href="#services" class="btn btn-white border px-5 py-3 rounded-4 fw-bold transition">
                Our Services
            </a>
        </div>
    </section>

    <!-- Why Choose DentalCare Section -->
    <section id="features" class="py-5 mb-5">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-dark mb-3">Why Choose DentalCare?</h2>
            <p class="text-secondary mx-auto" style="max-width: 600px;">
                We provide a comprehensive suite of tools designed to make dental and orthodontic management
                simple, secure, and efficient for everyone.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="dental-card h-100 shadow-sm border-0">
                    <div class="dental-avatar bg-primary-subtle text-primary mb-4" style="width: 56px; height: 56px; border-radius: 1rem;">
                        <i class="fas fa-calendar-check fs-4"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-3">Easy Appointment</h3>
                    <p class="text-secondary small mb-0">Fast and reliable online dental appointment system for patients and doctors.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="dental-card h-100 shadow-sm border-0">
                    <div class="dental-avatar bg-success-subtle text-success mb-4" style="width: 56px; height: 56px; border-radius: 1rem;">
                        <i class="fas fa-users fs-4"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-3">Patient Records</h3>
                    <p class="text-secondary small mb-0">Secure digital storage for all patient histories, X-rays, and treatment plans.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="dental-card h-100 shadow-sm border-0">
                    <div class="dental-avatar bg-info-subtle text-info mb-4" style="width: 56px; height: 56px; border-radius: 1rem;">
                        <i class="fas fa-robot fs-4"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-3">AI Intelligence</h3>
                    <p class="text-secondary small mb-0">Use advanced dental imaging analysis to detect issues before they become serious.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="bg-primary rounded-5 p-5 text-center text-white mb-5 shadow-lg">
        <div class="py-4">
            <h2 class="display-6 fw-bold mb-3">Are you a healthcare professional?</h2>
            <p class="mb-4 opacity-75 mx-auto" style="max-width: 600px;">Join hundreds of dentists who trust DentalCare for their daily operations and clinical management.</p>
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-5 py-3 rounded-4 fw-bold text-primary shadow">
                Create Your Account
            </a>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="dental-card p-5 border-0 shadow-sm mt-5">
        <div class="row g-5">
            <div class="col-lg-6">
                <h2 class="display-6 fw-bold text-dark mb-4">Contact Our Clinic</h2>
                <p class="text-secondary mb-5">We are here to answer your questions and provide the best dental care for your family. Feel free to reach out via any of the methods below.</p>

                <div class="d-flex flex-column gap-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="dental-avatar bg-primary-subtle text-primary rounded-circle" style="width: 48px; height: 48px;">
                            <i class="fas fa-phone-alt"></i>
                        </div>
                        <div>
                            <p class="dental-caption mb-0">Phone Number</p>
                            <p class="fw-bold text-dark mb-0">+1 (234) 567-890</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <div class="dental-avatar bg-success-subtle text-success rounded-circle" style="width: 48px; height: 48px;">
                            <i class="fab fa-whatsapp"></i>
                        </div>
                        <div>
                            <p class="dental-caption mb-0">WhatsApp</p>
                            <p class="fw-bold text-dark mb-0">+1 (234) 567-891</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <div class="dental-avatar bg-info-subtle text-info rounded-circle" style="width: 48px; height: 48px;">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <p class="dental-caption mb-0">Email Address</p>
                            <p class="fw-bold text-dark mb-0">contact@dentalcare.com</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <div class="dental-avatar bg-warning-subtle text-warning rounded-circle" style="width: 48px; height: 48px;">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div>
                            <p class="dental-caption mb-0">Clinic Location</p>
                            <p class="fw-bold text-dark mb-0">123 Health Ave, Medical City, MC 45678</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="bg-light p-5 rounded-5 h-100">
                    <h3 class="h5 fw-bold text-dark mb-4">Clinic Opening Hours</h3>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex justify-content-between p-3 bg-white rounded-4 shadow-sm border">
                            <span class="text-secondary fw-semibold">Monday - Friday</span>
                            <span class="text-primary fw-bold">09:00 AM - 08:00 PM</span>
                        </div>
                        <div class="d-flex justify-content-between p-3 bg-white rounded-4 shadow-sm border">
                            <span class="text-secondary fw-semibold">Saturday</span>
                            <span class="text-primary fw-bold">10:00 AM - 04:00 PM</span>
                        </div>
                        <div class="d-flex justify-content-between p-3 bg-white rounded-4 shadow-sm border border-danger-subtle">
                            <span class="text-secondary fw-semibold">Sunday</span>
                            <span class="text-danger fw-bold">Emergency Only</span>
                        </div>
                    </div>
                    <div class="mt-4 p-4 bg-warning-subtle text-warning-emphasis rounded-4 d-flex align-items-center gap-3 border border-warning">
                        <i class="fas fa-exclamation-circle fs-4"></i>
                        <p class="small mb-0 fw-medium">For immediate emergencies, please call our 24/7 hotline: <strong>+1 (800) 555-DENT</strong></p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
