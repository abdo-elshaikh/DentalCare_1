@model DentalCare.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Clinical practice, connected";
    ViewData["BodyClass"] = "landing-page";
}

<section class="home-hero">
    <div class="container home-hero__inner">
        <div class="home-hero__copy">
            <div class="section-kicker"><i class="fa-solid fa-wave-square"></i> Clinical operations + cephalometric AI</div>
            <h1>One workspace for every patient decision.</h1>
            <p>DentalCare connects appointments, medical records, patient profiles, and AI-assisted cephalometric analysis in a focused clinical workflow.</p>
            <div class="home-hero__actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Users" class="btn btn-brand btn-lg">Manage clinic team <i class="fa-solid fa-arrow-right"></i></a>
                    }
                    else if (User.IsInRole("Doctor"))
                    {
                        <a asp-controller="Doctor" asp-action="Dashboard" class="btn btn-brand btn-lg">Open doctor workspace <i class="fa-solid fa-arrow-right"></i></a>
                    }
                    else
                    {
                        <a asp-controller="Staff" asp-action="Dashboard" class="btn btn-brand btn-lg">Open reception workspace <i class="fa-solid fa-arrow-right"></i></a>
                    }
                }
                else
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-brand btn-lg">
                        Create clinic account <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-quiet btn-lg">Sign in</a>
                }
            </div>
            <div class="home-hero__assurance" aria-label="Platform capabilities">
                <span><i class="fa-solid fa-check"></i> Role-based access</span>
                <span><i class="fa-solid fa-check"></i> Unified clinical history</span>
                <span><i class="fa-solid fa-check"></i> AI report archive</span>
            </div>
        </div>

        <div class="clinical-visual">
            <img src="~/images/ceph-analysis-workspace.png" alt="Cephalometric radiograph with landmark tracing on a clinical workstation" />
            <div class="clinical-visual__status">
                <span class="status-dot"></span>
                <div><strong>Ceph analysis</strong><small>Integrated into the patient record</small></div>
                <i class="fa-solid fa-shield-halved"></i>
            </div>
        </div>
    </div>
</section>

<section class="live-metrics" aria-labelledby="activity-title">
    <div class="container">
        <div class="live-metrics__heading">
            <div><span class="section-kicker">Live clinic activity</span><h2 id="activity-title">The system, at a glance.</h2></div>
            <p>Current totals are read directly from this DentalCare installation.</p>
        </div>
        <div class="metrics-grid metrics-grid--four">
            <article class="metric-item">
                <div class="metric-icon metric-icon--teal"><i class="fa-solid fa-user-group"></i></div>
                <div><strong>@Model.TotalPatients.ToString("N0")</strong><span>Patient profiles</span></div>
            </article>
            <article class="metric-item">
                <div class="metric-icon metric-icon--blue"><i class="fa-regular fa-calendar-check"></i></div>
                <div><strong>@Model.AppointmentsToday.ToString("N0")</strong><span>Appointments today</span></div>
            </article>
            <article class="metric-item">
                <div class="metric-icon metric-icon--violet"><i class="fa-solid fa-file-waveform"></i></div>
                <div><strong>@Model.TotalMedicalRecords.ToString("N0")</strong><span>Medical records</span></div>
            </article>
            <article class="metric-item">
                <div class="metric-icon metric-icon--coral"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
                <div><strong>@Model.TotalAiAnalyses.ToString("N0")</strong><span>AI analysis reports</span></div>
            </article>
        </div>
    </div>
</section>

<section class="workflow-section" id="capabilities">
    <div class="container">
        <div class="workflow-intro">
            <span class="section-kicker">Built around the visit</span>
            <h2>From reception to clinical review, without losing context.</h2>
            <p>Each part of the project supports a real step in the clinic’s day, with access shaped around Admin, Doctor, and Staff roles.</p>
        </div>
        <div class="workflow-grid">
            <article class="workflow-item">
                <span>01</span><i class="fa-regular fa-calendar"></i>
                <h3>Coordinate appointments</h3>
                <p>Create, update, and track visits with patient, doctor, visit type, date, and status in one schedule.</p>
            </article>
            <article class="workflow-item">
                <span>02</span><i class="fa-solid fa-notes-medical"></i>
                <h3>Build a clinical history</h3>
                <p>Keep diagnoses, visit notes, treatment context, and medical records connected to each patient profile.</p>
            </article>
            <article class="workflow-item">
                <span>03</span><i class="fa-solid fa-head-side-virus"></i>
                <h3>Review ceph intelligence</h3>
                <p>Store landmarks, measurements, skeletal findings, confidence, treatment guidance, and review notes.</p>
            </article>
        </div>
    </div>
</section>

<section class="role-band">
    <div class="container role-band__inner">
        <div><span class="section-kicker section-kicker--light">Designed for the whole clinic</span><h2>One platform. Clear responsibilities.</h2></div>
        <div class="role-list">
            <div><i class="fa-solid fa-user-doctor"></i><span><strong>Doctors</strong>Patient care and AI review</span></div>
            <div><i class="fa-solid fa-clipboard-user"></i><span><strong>Staff</strong>Reception and scheduling</span></div>
            <div><i class="fa-solid fa-user-gear"></i><span><strong>Admins</strong>Users and role control</span></div>
        </div>
    </div>
</section>

<section class="home-cta">
    <div class="container home-cta__inner">
        <div><span class="section-kicker">Ready for a clearer clinic day?</span><h2>Bring your clinical workflow into focus.</h2></div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Users" class="btn btn-brand btn-lg">Manage clinic team <i class="fa-solid fa-arrow-right"></i></a>
            }
            else if (User.IsInRole("Doctor"))
            {
                <a asp-controller="Doctor" asp-action="Dashboard" class="btn btn-brand btn-lg">Open doctor workspace <i class="fa-solid fa-arrow-right"></i></a>
            }
            else
            {
                <a asp-controller="Staff" asp-action="Dashboard" class="btn btn-brand btn-lg">Open reception workspace <i class="fa-solid fa-arrow-right"></i></a>
            }
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-brand btn-lg">Create an account <i class="fa-solid fa-arrow-right"></i></a>
        }
    </div>
</section>
