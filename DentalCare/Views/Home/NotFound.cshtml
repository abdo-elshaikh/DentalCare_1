@{
    ViewData["Title"] = "Page Not Found";
}

<div class="container my-5 py-5 text-center animate-fade-in-up">
    <div class="glass-panel border-0 shadow-sm rounded-4 p-5 max-w-2xl mx-auto" style="max-width: 600px;">
        <div class="mb-4">
            <i class="fas fa-search-location text-primary opacity-50" style="font-size: 80px;"></i>
        </div>
        <h1 class="display-5 fw-bold text-dark mb-3 tracking-tight">404</h1>
        <h2 class="h4 fw-bold text-secondary mb-4">Page Not Found</h2>
        <p class="text-secondary mb-5 px-md-4">
            We couldn't find the page you were looking for. It might have been moved, deleted, or perhaps the URL was mistyped.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary bg-gradient fw-bold rounded-pill px-5 py-3 hover-lift shadow-sm tracking-wider text-uppercase" style="font-size: 0.9rem;">
            <i class="fas fa-home me-2"></i> Return to Dashboard
        </a>
    </div>
</div>
