@{
    ViewData["Title"] = "Page Not Found";
}

<section class="system-state">
    <div class="system-state__icon"><i class="fas fa-magnifying-glass"></i></div>
    <div class="section-kicker">Error 404</div>
    <h1>Page not found.</h1>
    <p>The requested page may have moved, been removed, or never existed. Return to DentalCare and continue from a known workspace.</p>
    <div class="system-state__actions">
        <a href="javascript:history.back()" class="btn btn-light px-4"><i class="fas fa-arrow-left"></i> Go back</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4"><i class="fas fa-house"></i> Return home</a>
    </div>
</section>
