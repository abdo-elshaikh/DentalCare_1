@model DentalCare.ViewModels.AdminUsersViewModel
@{
    ViewData["Title"] = "Team Management";
}

<div class="d-flex flex-column gap-4">
    <header class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-3">
        <div>
            <div class="section-kicker"><i class="fas fa-user-shield"></i> Administration</div>
            <h1 class="mb-2 mt-2">Clinic team</h1>
            <p class="text-secondary small mb-0">Create user accounts and control role-based access.</p>
        </div>
        <span class="badge bg-primary-subtle"><i class="fas fa-users me-1"></i> @Model.Users.Count active users</span>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info mb-0" role="status"><i class="fas fa-circle-info me-2"></i>@Model.StatusMessage</div>
    }
    <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

    <div class="row g-4 align-items-start">
        <div class="col-lg-4">
            <section class="glass-panel p-4">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="dental-avatar bg-primary-subtle"><i class="fas fa-user-plus"></i></div>
                    <div><h2 class="h5 mb-1 fw-bold">Add team member</h2><p class="small text-secondary mb-0">Create credentials and assign access.</p></div>
                </div>
                <form asp-action="CreateUser" method="post" class="d-grid gap-3">
                    <div>
                        <label asp-for="NewUser.Email" class="form-label dental-label">Email address</label>
                        <input asp-for="NewUser.Email" class="form-control" autocomplete="email" placeholder="name@clinic.com" />
                        <span asp-validation-for="NewUser.Email" class="field-error"></span>
                    </div>
                    <div>
                        <label asp-for="NewUser.Password" class="form-label dental-label">Temporary password</label>
                        <div class="field-control"><i class="fas fa-key"></i><input asp-for="NewUser.Password" class="form-control" autocomplete="new-password" placeholder="At least 8 characters" /><button type="button" class="password-toggle" aria-label="Show password" title="Show password"><i class="far fa-eye"></i></button></div>
                        <span asp-validation-for="NewUser.Password" class="field-error"></span>
                    </div>
                    <div>
                        <label asp-for="NewUser.Role" class="form-label dental-label">Clinic role</label>
                        <select asp-for="NewUser.Role" class="form-select">@foreach (var role in Model.Roles) { <option value="@role">@role</option> }</select>
                        <span asp-validation-for="NewUser.Role" class="field-error"></span>
                    </div>
                    <button type="submit" class="btn btn-primary mt-2"><i class="fas fa-plus"></i> Create user</button>
                </form>
            </section>
        </div>

        <div class="col-lg-8">
            <section class="glass-panel overflow-hidden">
                <div class="p-4 border-bottom"><h2 class="h5 fw-bold mb-1">Current users</h2><p class="small text-secondary mb-0">Roles take effect on the user's next request.</p></div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead><tr><th class="px-4">User</th><th>Role</th><th>Change role</th><th class="text-end px-4">Remove</th></tr></thead>
                        <tbody>
                        @if (!Model.Users.Any())
                        {
                            <tr><td colspan="4" class="text-center text-secondary py-5">No clinic users found.</td></tr>
                        }
                        else
                        {
                            @foreach (var user in Model.Users)
                            {
                                var currentRole = user.Roles.FirstOrDefault() ?? "No role";
                                <tr>
                                    <td class="px-4 py-3"><div class="d-flex align-items-center gap-3"><div class="dental-avatar bg-secondary-subtle">@(string.IsNullOrEmpty(user.Email) ? "?" : user.Email[..1].ToUpperInvariant())</div><div><div class="small fw-bold text-dark">@user.Email</div><div class="dental-caption">ID @user.Id[..Math.Min(8, user.Id.Length)]</div></div></div></td>
                                    <td><span class="badge @(currentRole == "Admin" ? "bg-danger-subtle" : currentRole == "Doctor" ? "bg-success-subtle" : "bg-primary-subtle")">@currentRole</span></td>
                                    <td><form asp-action="UpdateRole" method="post" class="d-flex align-items-center gap-2"><input type="hidden" name="userId" value="@user.Id" /><select name="role" class="form-select form-select-sm" style="min-width:110px">@foreach (var role in Model.Roles) { <option value="@role" selected="@(user.Roles.Contains(role) ? "selected" : null)">@role</option> }</select><button type="submit" class="btn btn-light btn-sm">Save</button></form></td>
                                    <td class="text-end px-4"><form asp-action="DeleteUser" method="post" onsubmit="return confirm('Remove this user from DentalCare?');"><input type="hidden" name="userId" value="@user.Id" /><button type="submit" class="icon-button text-danger" title="Delete user" aria-label="Delete @user.Email"><i class="fas fa-trash-alt"></i></button></form></td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
